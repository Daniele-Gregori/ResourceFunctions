Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "transcendentalRange", "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "transcendentalRange", "]"}], "=", 
    RowBox[{"Options", "[", "TranscendentalRange", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"transcendentalRange", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"f_", ",", "i_"}], "}"}], ",", "x_", ",", "y_", ",", 
    RowBox[{"z_", ":", "1"}], ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "transcendentalRange", "]"}]}]}], "]"}], ":=",
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"prec", "=", 
       RowBox[{"OptionValue", "[", "WorkingPrecision", "]"}]}], ",", "rg", ",",
       "rpl", ",", "sby", ",", "ddby"}], "}"}], ",", "\[IndentingNewLine]", 
    "\t\t", "\[IndentingNewLine]", "\t\t", 
    RowBox[{"(*", 
     RowBox[{"raw", " ", "redundant", " ", "range"}], "*)"}], 
    "\[IndentingNewLine]", "\t\t", 
    RowBox[{
     RowBox[{"rg", "=", 
      RowBox[{"coreRange", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"f", ",", "i"}], "}"}], ",", "x", ",", "y", ",", "z", ",", 
        RowBox[{"optGenerators", "[", "opts", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t", "\[IndentingNewLine]", "\t\t", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"delete", " ", "duplicates", " ", "by", " ", "N"}], " ", "+", 
       " ", 
       RowBox[{
       "choose", " ", "the", " ", "one", " ", "with", " ", "minimal", " ", 
        "argument"}]}], "*)"}], "\[IndentingNewLine]", "\t\t", 
     RowBox[{"rpl", "=", 
      RowBox[{"Switch", "[", 
       RowBox[{"i", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
        RowBox[{
         RowBox[{"f", "[", "arg_", "]"}], ":>", 
         RowBox[{"Abs", "@", 
          RowBox[{"N", "[", 
           RowBox[{"arg", ",", "prec"}], "]"}]}]}], ",", 
        "\[IndentingNewLine]", "\t\t\t\t\t", "2", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Times", "[", 
           RowBox[{"a_", ",", " ", 
            RowBox[{"f", "[", "arg_", "]"}]}], "]"}], "|", 
          RowBox[{"f", "[", "arg_", "]"}]}], ":>", 
         RowBox[{"Abs", "@", 
          RowBox[{"N", "[", 
           RowBox[{"arg", ",", "prec"}], "]"}]}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"ddby", "=", 
      RowBox[{"Values", "@", 
       RowBox[{"Map", "[", "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{
         RowBox[{
          RowBox[{"First", "@", 
           RowBox[{"MinimalBy", "[", 
            RowBox[{"#", ",", 
             RowBox[{
              RowBox[{"#", "/.", "rpl"}], "&"}], ",", "1"}], "]"}]}], "&"}], ",",
          "\t", "\[IndentingNewLine]", "\t\t\t", "\[IndentingNewLine]", 
         "\t\t\t", 
         RowBox[{"GroupBy", "[", 
          RowBox[{"rg", ",", 
           RowBox[{
            RowBox[{"N", "[", 
             RowBox[{"#", ",", "prec"}], "]"}], "&"}]}], "]"}]}], "]"}]}]}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"(", "rev", ")"}], "sort", " ", "by", " ", "N"}], "*)"}], 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"sby", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"z", ">", "0"}], ",", "SortBy", ",", "ReverseSortBy"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\t\t", 
     RowBox[{"sby", "[", 
      RowBox[{"ddby", ",", 
       RowBox[{
        RowBox[{"N", "[", 
         RowBox[{"#", ",", "prec"}], "]"}], "&"}]}], "]"}]}]}], 
   "]"}]}]}], "Code",
