  3.980775556306807*^9}},ExpressionUUID->"55e3e722-46da-4816-a754-\
4fe0c1154aa0"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "fareyRange", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fareyRange", "[", 
   RowBox[{"r1_", ",", "r2_", ",", "r3_"}], "]"}], ":=", 
  "\[IndentingNewLine]", "\t", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"r3", ">=", "1"}], ",", "\[IndentingNewLine]", "\t\t", 
    RowBox[{
     RowBox[{"ResourceFunction", "[", "\"\<FareyRange\>\"", "]"}], "[", 
     RowBox[{"r1", ",", "r2", ",", "r3"}], "]"}], ",", "\[IndentingNewLine]", 
    "\t\t", 
    RowBox[{"Which", "[", 
     RowBox[{"(*", 
      RowBox[{
      "intuitive", " ", "alternative", " ", "reciprocal", " ", "step"}], 
      "*)"}], "\[IndentingNewLine]", "\t\t\t", 
     RowBox[{
      RowBox[{"MatchQ", "[", 
       RowBox[{"r3", ",", 
        RowBox[{"Rational", "[", 
         RowBox[{"1", ",", "_"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
      "\t\t\t\t", 
      RowBox[{
       RowBox[{"ResourceFunction", "[", "\"\<FareyRange\>\"", "]"}], "[", 
       RowBox[{"r1", ",", "r2", ",", 
        RowBox[{"1", "/", "r3"}]}], "]"}], ",", "\[IndentingNewLine]", 
      "\t\t\t", 
      RowBox[{"MatchQ", "[", 
       RowBox[{"r3", ",", 
        RowBox[{"Rational", "[", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "_"}], "]"}]}], "]"}], ",", 
      "\[IndentingNewLine]", "\t\t\t\t", 
      RowBox[{"Reverse", "[", 
       RowBox[{
        RowBox[{"ResourceFunction", "[", "\"\<FareyRange\>\"", "]"}], "[", 
        RowBox[{"r2", ",", "r1", ",", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "r3"}]}], "]"}], "]"}], ",", 
      "\[IndentingNewLine]", "\t\t\t", "True", ",", "\[IndentingNewLine]", 
      "\t\t\t\t", 
      RowBox[{"failureFareyStep", "[", "r3", "]"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
