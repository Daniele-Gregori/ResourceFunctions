     RowBox[{
      RowBox[{"{", 
       RowBox[{"sel", ",", "eln", ",", "i"}], "}"}], ",", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"eln", "=", 
        RowBox[{"list", "[", 
