Cell[BoxData[
 RowBox[{
  RowBox[{"coreRange", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", ":", "ArcCosh"}], ",", "2"}], "}"}], ",", "x_", ",", "y_", 
    ",", 
    RowBox[{"z_", ":", "1"}], ",", 
    RowBox[{"opt_String", ":", "\"\<Rational\>\""}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"fun", "=", 
       RowBox[{
        RowBox[{"#", " ", 
         RowBox[{"f", "[", "#2", "]"}]}], "&"}]}], ",", 
      RowBox[{"min", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", ">", "0"}], ",", "x", ",", "y"}], "]"}]}], ",", 
      RowBox[{"max", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", ">", "0"}], ",", "y", ",", "x"}], "]"}]}], ",", "rc", ",",
       "ra", ",", "cs", ",", "as", ",", "ncs", ",", "nas", ",", "outp", ",", 
      "outn"}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"preprRange", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", "z", ",", "opt"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", "0", "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"domain", "[", "f", "]"}], ",", "1", ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
        "rc", ",", "ra", ",", "cs", ",", "as", ",", "ncs", ",", "nas"}], 
        "}"}]}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outp", ":=", 
      RowBox[{"Join", "[", "\[IndentingNewLine]", 
       RowBox[{"monotonicOuter", "[", 
        RowBox[{"fun", ",", 
         RowBox[{"{", 
          RowBox[{"min", ",", "max"}], "}"}], ",", 
         RowBox[{"cs", "[", "2", "]"}], ",", 
         RowBox[{"as", "[", "1", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}], ",", "1"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outn", ":=", 
      RowBox[{"Join", "[", 
       RowBox[{"monotonicOuter", "[", 
        RowBox[{"fun", ",", 
         RowBox[{"{", 
          RowBox[{"min", ",", "max"}], "}"}], ",", 
         RowBox[{"cs", "[", "1", "]"}], ",", 
         RowBox[{"as", "[", "1", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0", "<=", "x", "<=", "y"}], "||", 
        RowBox[{"0", "<=", "y", "<=", "x"}]}], ",", "outp", ",", 
       RowBox[{
        RowBox[{"x", "<=", "y", "<=", "0"}], "||", 
        RowBox[{"y", "<=", "x", "<=", "0"}]}], ",", "outn", ",", 
       RowBox[{
        RowBox[{"x", "<=", "0"}], "&&", 
        RowBox[{"y", ">=", "0"}]}], ",", 
       RowBox[{"outn", "~", "Join", "~", "outp"}], ",", 
       RowBox[{
        RowBox[{"y", "<=", "0"}], "&&", 
        RowBox[{"x", ">=", "0"}]}], ",", 
       RowBox[{"outp", "~", "Join", "~", "outn"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
