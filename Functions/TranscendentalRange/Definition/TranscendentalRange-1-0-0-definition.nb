Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"outerTranscRange", "[", 
    RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], "/;", 
   RowBox[{"z", ">", "0"}]}], ":=", "\[IndentingNewLine]", 
  RowBox[{"SortBy", "[", 
   RowBox[{
    RowBox[{"DeleteDuplicatesBy", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Select", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Outer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"#", " ", 
             RowBox[{"Exp", "[", "#2", "]"}]}], "&"}], ",", 
           RowBox[{"Range", "[", 
            RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
           RowBox[{"Range", "[", 
            RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], "]"}], "//", 
         "Flatten"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "<=", "#", "<=", "y"}], "&&", 
          RowBox[{"!", 
           RowBox[{"Element", "[", 
            RowBox[{"#", ",", "Algebraics"}], "]"}]}]}], "&"}]}], "]"}], ",", 
      "N"}], "]"}], ",", "N"}], "]"}]}]], "Input",
