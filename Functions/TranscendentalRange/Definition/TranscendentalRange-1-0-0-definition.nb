      "CodeAssistant", "CodeWriter", "PlainChat", "RawModel"}, 
     "ToolSelections" -> <|
      "DocumentationLookup" -> <|
        "CodeAssistant" -> True, "CodeWriter" -> True|>, 
       "DocumentationSearcher" -> <|
        "CodeAssistant" -> True, "CodeWriter" -> True|>|>|>|>,
 CellChangeTimes->{{3.980776234840427*^9, 3.9807762485115423`*^9}, {
  3.980776486220607*^9, 
  3.980776593163271*^9}},ExpressionUUID->"027184f3-8222-406c-860d-\
024f9403931a"],

