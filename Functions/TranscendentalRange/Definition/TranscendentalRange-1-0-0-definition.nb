Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "combinedNaiveRange", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "combinedNaiveRange", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"WorkingPrecision", "->", "MachinePrecision"}], ",", 
      RowBox[{"\"\<GeneratorsDomain\>\"", "->", "Rationals"}]}], "}"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"combinedNaiveRange", "[", 
    RowBox[{"x_", ",", "y_", ",", 
     RowBox[{"z_", ":", "1"}], ",", "funs_List", ",", 
     RowBox[{"opts", ":", 
      RowBox[{"OptionsPattern", "[", "combinedNaiveRange", "]"}]}]}], "]"}], "/;", 
   RowBox[{"NumericQ", "[", "z", "]"}]}], ":=", "\[IndentingNewLine]", "\t", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"funL", ",", "patf", ",", "extrarg", ",", 
      RowBox[{"prec", "=", 
       RowBox[{"OptionValue", "[", "WorkingPrecision", "]"}]}], ",", 
      RowBox[{"optalg", "=", 
       RowBox[{"optGenerators", "[", 
        RowBox[{"OptionValue", "[", "\"\<GeneratorsDomain\>\"", "]"}], 
        "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", "\t\t", 
    RowBox[{
     RowBox[{"funL", "=", 
      RowBox[{"If", "[", 
