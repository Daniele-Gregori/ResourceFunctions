Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"method", "=", "Sinh"}], "}"}], ",", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"args", " ", "=", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"RandomInteger", "[", 
             RowBox[{"{", 
              RowBox[{"15", ",", " ", "20"}], "}"}], "]"}], ",", " ", 
            RowBox[{"RandomInteger", "[", 
             RowBox[{"{", 
              RowBox[{"0", ",", " ", "5"}], "}"}], "]"}], ",", " ", 
            RowBox[{
             RowBox[{"RandomInteger", "[", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "7"}], "}"}], "]"}], "/", 
             RowBox[{"RandomInteger", "[", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "7"}], "}"}], "]"}]}]}], "}"}], " ", "//",
           " ", "Echo"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"test", "[", 
