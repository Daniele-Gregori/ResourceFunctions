          RowBox[{"as", "[", "3", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", "1"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "1", "]"}], ",", 
          RowBox[{"as", "[", "1", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "1"}], "]"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outn", ":=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "1", "]"}], ",", 
          RowBox[{"as", "[", "3", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"-", "1"}]}], "]"}], ",", 
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "2", "]"}], ",", 
          RowBox[{"as", "[", "1", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}], ",", 
          RowBox[{"-", "1"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Which", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"0", "<=", "x", "<=", "y"}], "||", 
