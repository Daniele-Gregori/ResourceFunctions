     "VisiblePersonas" -> {
      "CodeAssistant", "CodeWriter", "PlainChat", "RawModel"}, 
     "ToolSelections" -> <|
      "DocumentationLookup" -> <|
        "CodeAssistant" -> True, "CodeWriter" -> True|>, 
       "DocumentationSearcher" -> <|
        "CodeAssistant" -> True, "CodeWriter" -> True|>|>|>|>,
 CellChangeTimes->{{3.973949207614225*^9, 3.973949314645547*^9}, {
  3.9739493490308647`*^9, 3.973949391064075*^9}, {3.973949499520529*^9, 
  3.973949552622159*^9}, {3.973949594002737*^9, 3.973949749984641*^9}, {
