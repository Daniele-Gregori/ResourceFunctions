Cell[TextData[{
 "For the method ",
 ButtonBox["Power",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Power"],
 ", only algebraic irrational generators in the exponent ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "7f47cd68-f3dc-46f1-810c-4e3920112e07"],
 " can produce transcendental numbers."
}], "Notes",
