Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rooteq", "[", 
    RowBox[{"ArcSec", ",", "2"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", " ", 
       RowBox[{
        RowBox[{"x", " ", 
         RowBox[{"ArcSec", "[", "x", "]"}]}], ",", "x"}], "]"}], "==", "0"}], 
     "//", "PowerExpand"}], "//", "Simplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"turning", "[", 
    RowBox[{"ArcSec", ",", "2"}], "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prec", "=", "1000"}], "}"}], ",", 
     RowBox[{
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"rooteq", "[", 
         RowBox[{"ArcSec", ",", "2"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "10"}]}], "}"}], ",", 
        RowBox[{"PrecisionGoal", "->", "prec"}], ",", 
        RowBox[{"WorkingPrecision", "->", "prec"}]}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "]"}]}], ";"}]}], "Input",
