Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"TranscendentalRange", "[", 
    RowBox[{
     StyleBox["x", "TI"], ",", 
     StyleBox["y", "TI"], ",", 
     StyleBox["z", "TI"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "9573f235-6dae-4ec4-a27f-a63e1862ce7f"],
 " can be simply generated through the Outer product of the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"#1", " ", 
     RowBox[{"Exp", "[", "#2", "]"}]}], "&"}], TraditionalForm]],
  ExpressionUUID->"f0732083-7811-4dbe-8616-90153103bfc4"],
 ", with both arguments running over ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Range", "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}], TraditionalForm]],
  ExpressionUUID->"c63c0128-b34f-450d-8562-c65fda600e81"],
 ", suitably restricted to the elements within the bounds ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "60eae4cb-7dc2-42b5-ac69-0ba54f05b059"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", "y"}], TraditionalForm]],ExpressionUUID->
  "907ebc61-396c-48ff-af26-a26109a12551"],
 ", not belonging to the Algebraics and sorted, as follows:"
}], "Text",
