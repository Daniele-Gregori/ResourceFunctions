Cell[BoxData[{
 RowBox[{"ClearAll", "[", "domain", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"domain", "[", "_", "]"}], "=", 
    RowBox[{"True", "&"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Log", "]"}], "=", 
   RowBox[{
    RowBox[{"#", ">", "0"}], "&"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Power", "]"}], "=", 
   RowBox[{
    RowBox[{"#", ">", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Coth", "]"}], "=", 
   RowBox[{
    RowBox[{"#", "!=", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Csch", "]"}], "=", 
   RowBox[{
    RowBox[{"#", "!=", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcCosh", "]"}], "=", 
   RowBox[{
    RowBox[{"#", ">=", "1"}], "&"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcTanh", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "1"}], "<", "#", "<", "1"}], "&"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcCoth", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "#", "]"}], ">", "1"}], "&"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcSech", "]"}], "=", 
   RowBox[{
    RowBox[{"0", "<", "#", "<=", "1"}], "&"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcCsch", "]"}], "=", 
   RowBox[{
    RowBox[{"#", "!=", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Tan", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "@", 
      RowBox[{"FractionalPart", "[", 
       RowBox[{"#", "/", "\[Pi]"}], "]"}]}], "!=", 
     RowBox[{"1", "/", "2"}]}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Sec", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "@", 
      RowBox[{"FractionalPart", "[", 
       RowBox[{"#", "/", "\[Pi]"}], "]"}]}], "!=", 
     RowBox[{"1", "/", "2"}]}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Cot", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FractionalPart", "[", 
      RowBox[{"#", "/", "\[Pi]"}], "]"}], "!=", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "Csc", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FractionalPart", "[", 
      RowBox[{"#", "/", "\[Pi]"}], "]"}], "!=", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcSin", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "#", "]"}], "<=", "1"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcCos", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "#", "]"}], "<=", "1"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcCot", "]"}], "=", 
   RowBox[{
    RowBox[{"#", "!=", "0"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcSec", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "#", "]"}], ">=", "1"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"domain", "[", "ArcCsc", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Abs", "[", "#", "]"}], ">=", "1"}], "&"}]}], ";"}]}], "Input",
