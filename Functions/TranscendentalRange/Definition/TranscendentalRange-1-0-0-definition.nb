Cell[TextData[{
 "The option \"GeneratorsDomain\" can be used to specify whether ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "7afd59ba-a758-4bbe-a75e-0ccc27846bd4"],
 ", ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "a863a78f-ba13-456b-9b79-d910eefc0797"],
 " (function argument and coefficient) should belong to the ",
 ButtonBox["Rationals",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Rationals"],
 " or to the ",
 ButtonBox["Algebraics",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Algebraics"],
 ", as generated by ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Range", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Range",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6558a540-8783-4fe0-ab3f-a548276e06a3"],
 " and the resource function \"",
 ButtonBox["AlgebraicRange",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/FunctionRepository/resources/\
AlgebraicRange"], None},
  ButtonNote->
   "https://resources.wolframcloud.com/FunctionRepository/resources/\
AlgebraicRange"],
 "\", respectively. These are also restricted to be elements of the ",
 ButtonBox["Reals",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Reals"],
 " and no complex number can be generated."
}], "Notes",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
