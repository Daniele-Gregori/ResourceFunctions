  3.980784414884655*^9}},ExpressionUUID->"23d8c740-5816-4af3-aae5-\
93ae7cc384b6"],

Cell[TextData[{
 "By default, the range elements are generated according to the \
Lindemann-Weierstrass theorem, that is linear combinations of exponentials ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      SubscriptBox["t", "i"], "=", " ", 
      RowBox[{"b", " ", Cell[TextData[Cell[BoxData[
        FormBox[
         SuperscriptBox["\[ExponentialE]", "a"], TraditionalForm]],
        ExpressionUUID->"ca4a0354-56d6-4d8b-a299-c12ce1940672"]],
        ExpressionUUID->"30538690-d1f4-4e7e-a15a-544ab075429d"]}]}], 
     TraditionalForm]],ExpressionUUID->
    "a1eea78b-8ddf-4438-aceb-6684c4ec8589"]],ExpressionUUID->
    "fabb87b7-7d6d-4023-8ab4-756f0a66b6d3"], TraditionalForm]],ExpressionUUID->
  "70946b6b-5ca1-45a7-add2-67b8872022b9"],
 ", ",
 ButtonBox["for all",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ForAll"],
 " ",
 ButtonBox["algebraic",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Algebraics"],
 " arguments and coefficients ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "4441ba29-200d-4630-944f-a198110bf8bf"],
 ", ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "db6611a2-48e9-4e7d-b8be-4d7299e830dc"],
 " that are ",
 ButtonBox["members",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/MemberQ"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TagBox[
     ButtonBox[
      StyleBox["Range", "SymbolsRefLink",
       ShowStringCharacters->True,
       FontFamily->"Source Sans Pro"],
      BaseStyle->Dynamic[
        FEPrivate`If[
         CurrentValue["MouseOver"], {
         "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
      ButtonData->"paclet:ref/Range",
      ContentPadding->False],
     MouseAppearanceTag["LinkHand"]], "[", 
    RowBox[{"x", ",", "y"}], "]"}], TraditionalForm]],ExpressionUUID->
  "ebf2a258-d820-479c-95aa-a2034d11cab1"],
 ", or possibly ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TagBox[
     ButtonBox[
      StyleBox["Range", "SymbolsRefLink",
       ShowStringCharacters->True,
       FontFamily->"Source Sans Pro"],
      BaseStyle->Dynamic[
        FEPrivate`If[
         CurrentValue["MouseOver"], {
         "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
      ButtonData->"paclet:ref/Range",
      ContentPadding->False],
     MouseAppearanceTag["LinkHand"]], "[", 
    RowBox[{"x", ",", "y", ",", "s"}], "]"}], TraditionalForm]],
  ExpressionUUID->"bf9e68e2-b2ff-44a5-b259-f2e94bea4196"],
 " using also a step parameter ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "1d778e83-f901-4b3b-aacf-189a1d93c698"],
 " as third argument."
}], "Notes",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
     "ServiceDefaultModel" -> <|
      "LLMKit" -> Automatic, "OpenAI" -> "chatgpt-4o-latest", "Anthropic" -> 
