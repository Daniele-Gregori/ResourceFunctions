Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "elementary", " ", "testing", " ", "range", " ", "with", " ", "only", " ", 
    "one", " ", "function", " ", "at", " ", "a", " ", "time"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", "elemNaiveRange", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"elemNaiveRange", "[", 
      RowBox[{"x_", ",", "y_", ",", 
       RowBox[{"z_", ":", "1"}], ",", 
       RowBox[{"fun", ":", 
        RowBox[{"_Symbol", "|", "_String"}], ":", "Exp"}], ",", 
       RowBox[{"opt_String", ":", "\"\<Rational\>\""}]}], "]"}], "/;", 
     RowBox[{"NumericQ", "[", "z", "]"}]}], ":=", "\[IndentingNewLine]", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rgmain", ",", 
        RowBox[{"min", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"x", "<", "y"}], ",", "x", ",", "y"}], "]"}]}], ",", 
        RowBox[{"max", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"x", "<", "y"}], ",", "y", ",", "x"}], "]"}]}]}], "}"}], ",",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"arguments", " ", "basic", " ", "range"}], ",", " ", 
        RowBox[{"to", " ", "be", " ", "restricted", " ", "below"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"rgmain", "=", 
        RowBox[{"range", "[", 
         RowBox[{"x", ",", "y", ",", "z", ",", "opt"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"DeleteCases", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "Select", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{
            "Outer", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{"function", " ", "with", " ", "two", " ", "arguments"}],
               "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"Which", "[", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"MemberQ", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"Exp", ",", "Log", ",", 
                    RowBox[{"Splice", "@", 
                    RowBox[{"Join", "[", 
                    RowBox[{
                    "$trig", ",", "$hyp", ",", "$invtrig", ",", "$invhyp"}], 
                    "]"}]}]}], "}"}], ",", "fun"}], "]"}], ",", 
                 "\[IndentingNewLine]", "\t", 
                 RowBox[{"#1", 
                  RowBox[{"fun", "[", "#2", "]"}]}], ",", 
                 "\[IndentingNewLine]", 
                 RowBox[{"fun", "===", "Power"}], ",", "\[IndentingNewLine]", 
                 "\t", 
                 RowBox[{"#2", "^", "#1"}], ",", "\[IndentingNewLine]", 
                 "True", ",", "\[IndentingNewLine]", "\t", "$Failed"}], "]"}],
                "&"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{"first", " ", "argument"}], "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"Which", "[", "\[IndentingNewLine]", "\t", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"Exp", ",", "Log", ",", 
                    RowBox[{"Splice", "@", 
                    RowBox[{"Join", "[", 
                    RowBox[{
                    "$trig", ",", "$hyp", ",", "$invtrig", ",", "$invhyp"}], 
                    "]"}]}]}], "}"}], ",", "fun"}], "]"}], ",", 
                "\[IndentingNewLine]", "\t\t", "rgmain", ",", 
                "\[IndentingNewLine]", "\t", 
                RowBox[{"fun", "===", "Power"}], ",", "\[IndentingNewLine]", 
                "\t\t\t", 
                RowBox[{"DeleteCases", "[", 
                 RowBox[{"rgmain", ",", "_Rationals"}], "]"}]}], "]"}], ",", 
              "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{"second", " ", "argument"}], "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{
              "Which", "[", "\[IndentingNewLine]", "\t\t", 
               "\[IndentingNewLine]", "\t\t", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                   "Log", ",", "Power", ",", "Coth", ",", "Csch", ",", 
                    "ArcCosh", ",", "ArcTanh", ",", "ArcCoth", ",", "ArcSech",
                     ",", "ArcCsch", ",", "Tan", ",", "Sec", ",", "Cot", ",", 
                    "Csc", ",", "ArcSin", ",", "ArcCos", ",", "ArcCot", ",", 
                    "ArcSec", ",", "ArcCsc"}], "}"}], ",", "fun"}], "]"}], ",",
                 "\[IndentingNewLine]", "\t\t\t", 
                RowBox[{"Select", "[", 
                 RowBox[{"rgmain", ",", 
                  RowBox[{"domain", "[", "fun", "]"}]}], "]"}], ",", 
                "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", "True", 
                ",", "\[IndentingNewLine]", "\t\t\t", "rgmain"}], 
               "\[IndentingNewLine]", "\t\t", "]"}]}], "]"}], "//", 
            "Flatten"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"min", "<=", "#", "<=", "max"}], "&"}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"_", "?", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Element", "[", 
             RowBox[{"#", ",", "Algebraics"}], "]"}], "&"}], ")"}]}]}], 
        "]"}]}]}], "]"}]}]}]}]], "Input",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
     "ServiceDefaultModel" -> <|
      "LLMKit" -> Automatic, "OpenAI" -> "chatgpt-4o-latest", "Anthropic" -> 
