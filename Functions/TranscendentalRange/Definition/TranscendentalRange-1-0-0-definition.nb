 RowBox[{
  RowBox[{"coreRange", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", ":", "ArcCoth"}], ",", "2"}], "}"}], ",", "x_", ",", "y_", 
    ",", 
    RowBox[{"z_", ":", "1"}], ",", 
    RowBox[{"opt_String", ":", "\"\<Rational\>\""}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"fun", "=", 
       RowBox[{
        RowBox[{"#", " ", 
         RowBox[{"f", "[", "#2", "]"}]}], "&"}]}], ",", 
      RowBox[{"min", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", ">", "0"}], ",", "x", ",", "y"}], "]"}]}], ",", 
      RowBox[{"max", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", ">", "0"}], ",", "y", ",", "x"}], "]"}]}], ",", "rc", ",",
       "ra", ",", "cs", ",", "as", ",", "ncs", ",", "nas", ",", "outp", ",", 
      "outn"}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"preprRange", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", "z", ",", "opt"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", "0", "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"domain", "[", "f", "]"}], ",", "0", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
        "rc", ",", "ra", ",", "cs", ",", "as", ",", "ncs", ",", "nas"}], 
        "}"}]}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outp", ":=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
