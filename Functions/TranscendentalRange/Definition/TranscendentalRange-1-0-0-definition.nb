      RowBox[{"min", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", ">", "0"}], ",", "x", ",", "y"}], "]"}]}], ",", 
      RowBox[{"max", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", ">", "0"}], ",", "y", ",", "x"}], "]"}]}], ",", "rc", ",",
       "ra", ",", "cs", ",", "as", ",", "ncs", ",", "nas", ",", "outp", ",", 
      "outn", ",", 
      RowBox[{"turn", "=", 
       RowBox[{"turning", "[", 
        RowBox[{"f", ",", "2"}], "]"}]}]}], "}"}], ",", "\[IndentingNewLine]",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"preprRange", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", "y", ",", "z", ",", "opt"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", "0", "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"domain", "[", "f", "]"}], ",", "1", ",", 
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", "turn", "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
        "rc", ",", "ra", ",", "cs", ",", "as", ",", "ncs", ",", "nas"}], 
        "}"}]}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outp", ":=", 
      RowBox[{"Join", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "2", "]"}], ",", 
          RowBox[{"as", "[", "2", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", "1"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "2", "]"}], ",", 
          RowBox[{"as", "[", "1", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", "1"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outn", ":=", 
      RowBox[{"Join", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "1", "]"}], ",", 
          RowBox[{"as", "[", "2", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"-", "1"}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}], ",", 
          RowBox[{"cs", "[", "1", "]"}], ",", 
          RowBox[{"as", "[", "1", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"-", "1"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0", "<=", "x", "<=", "y"}], "||", 
        RowBox[{"0", "<=", "y", "<=", "x"}]}], ",", "outp", ",", 
       RowBox[{
        RowBox[{"x", "<=", "y", "<=", "0"}], "||", 
