             RowBox[{"Inactive", "[", "Power", "]"}], "[", 
             RowBox[{
              RowBox[{"{", "b_", "}"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"Inactive", "[", "Times", "]"}], "[", 
                RowBox[{"m_", ",", 
                 RowBox[{
                  RowBox[{"Inactive", "[", "Power", "]"}], "[", 
                  RowBox[{"n_", ",", 
                   RowBox[{"-", "1"}]}], "]"}]}], "]"}], "|", 
               RowBox[{"{", 
                RowBox[{"m_", ",", "n_"}], "}"}]}]}], "]"}]}], "]"}], ":>", 
          "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t", 
          RowBox[{"Table", "[", 
           RowBox[{"b", ",", 
            RowBox[{
             RowBox[{"Abs", "[", "n", "]"}], "+", 
             RowBox[{"Abs", "[", "m", "]"}]}]}], "]"}]}]}], ",", 
        "\[IndentingNewLine]", "\t\t\t", "_Integer", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}], "/.", " ", 
      RowBox[{
       RowBox[{"j_Integer", "?", "NonPositive"}], ":>", 
       RowBox[{
        RowBox[{"-", "j"}], "+", "1"}]}]}], "\[IndentingNewLine]", "\t\t\t\t",
      "/.", 
     RowBox[{"i_Integer", ":>", 
