Cell[BoxData[
 RowBox[{
  RowBox[{"coreRange", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", " ", ":", " ", "ArcCot"}], ",", " ", "2"}], "}"}], ",", 
    " ", "x_", ",", " ", "y_", ",", " ", 
    RowBox[{"z_", " ", ":", " ", "1"}], ",", " ", 
    RowBox[{"opt_String", " ", ":", " ", "\"\<Rational\>\""}]}], "]"}], " ", ":=",
   " ", "\n", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"fun", " ", "=", " ", 
       RowBox[{
        RowBox[{"#", " ", 
         RowBox[{"f", "[", "#2", "]"}]}], " ", "&"}]}], ",", " ", 
      RowBox[{"min", " ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", " ", ">", " ", "0"}], ",", " ", "x", ",", " ", "y"}], 
        "]"}]}], ",", " ", 
      RowBox[{"max", " ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", " ", ">", " ", "0"}], ",", " ", "y", ",", " ", "x"}], 
        "]"}]}], ",", " ", "rc", ",", " ", "ra", ",", " ", "cs", ",", " ", 
      "as", ",", " ", "ncs", ",", " ", "nas", ",", " ", "outp", ",", " ", 
      "outn"}], "}"}], ",", "\n", "  ", "\n", "  ", 
    RowBox[{
     RowBox[{"preprRange", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y", ",", " ", "z", ",", " ", "opt"}], "}"}], ",",
        "\n", "   ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"{", "}"}], ",", " ", 
         RowBox[{"{", "0", "}"}]}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"domain", "[", "f", "]"}], ",", " ", "0", ",", " ", 
         RowBox[{"{", "0", "}"}], ",", " ", 
         RowBox[{"{", "0", "}"}]}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{
        "rc", ",", " ", "ra", ",", " ", "cs", ",", " ", "as", ",", " ", "ncs",
          ",", " ", "nas"}], "}"}]}], "]"}], ";", "\n", "  ", "\n", "  ", 
     RowBox[{"outp", " ", ":=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", " ", 
          RowBox[{"{", 
           RowBox[{"min", ",", " ", "max"}], "}"}], ",", " ", 
          RowBox[{"cs", "[", "2", "]"}], ",", " ", 
          RowBox[{"as", "[", "2", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", 
            RowBox[{"-", "1"}]}], "}"}], ",", " ", "1"}], "]"}], ",", "\n", 
        "    ", 
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", " ", 
          RowBox[{"{", 
           RowBox[{"min", ",", " ", "max"}], "}"}], ",", " ", 
          RowBox[{"cs", "[", "1", "]"}], ",", " ", 
          RowBox[{"as", "[", "1", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", "1"}], 
         "]"}]}], "]"}]}], ";", "\n", "  ", "\n", "  ", 
     RowBox[{"outn", " ", ":=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", " ", 
          RowBox[{"{", 
           RowBox[{"min", ",", " ", "max"}], "}"}], ",", " ", 
          RowBox[{"cs", "[", "1", "]"}], ",", " ", 
          RowBox[{"as", "[", "2", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", 
            RowBox[{"-", "1"}]}], "}"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}], ",", " ", "\n", "  ", 
        RowBox[{"monotonicOuter", "[", 
         RowBox[{"fun", ",", " ", 
          RowBox[{"{", 
           RowBox[{"min", ",", " ", "max"}], "}"}], ",", " ", 
          RowBox[{"cs", "[", "2", "]"}], ",", " ", 
          RowBox[{"as", "[", "1", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", 
          RowBox[{"-", "1"}]}], "]"}]}], "]"}]}], ";", "\n", "  ", "\n", "  ", 
     RowBox[{"Which", "[", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"0", " ", "<=", " ", "x", " ", "<=", " ", "y"}], " ", "||", 
        " ", 
        RowBox[{"0", " ", "<=", " ", "y", " ", "<=", " ", "x"}]}], ",", " ", 
       "outp", ",", "\n", "   ", 
       RowBox[{
        RowBox[{"x", " ", "<=", " ", "y", " ", "<=", " ", "0"}], " ", "||", 
        " ", 
        RowBox[{"y", " ", "<=", " ", "x", " ", "<=", " ", "0"}]}], ",", " ", 
       "outn", ",", "\n", "   ", 
       RowBox[{
        RowBox[{"x", " ", "<=", " ", "0"}], " ", "&&", " ", 
        RowBox[{"y", " ", ">=", " ", "0"}]}], ",", " ", 
       RowBox[{"outn", "~", "Join", "~", "outp"}], ",", "\n", "   ", 
       RowBox[{
        RowBox[{"y", " ", "<=", " ", "0"}], " ", "&&", " ", 
        RowBox[{"x", " ", ">=", " ", "0"}]}], ",", " ", 
       RowBox[{"outp", "~", "Join", "~", "outn"}]}], "]"}]}]}], 
   "]"}]}]], "Code",
