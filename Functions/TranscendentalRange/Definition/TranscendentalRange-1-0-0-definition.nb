Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "formulaComplexity", "]"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"digitSum", "[", "int_Integer", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"$VersionNumber", ">=", "14"}], ",", 
     RowBox[{"DigitSum", "[", "int", "]"}], ",", 
     RowBox[{"Total", "@", 
      RowBox[{"IntegerDigits", "[", "int", "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"formulaComplexity", "[", 
   RowBox[{"form_", "?", "NumericQ"}], "]"}], ":=", "\[IndentingNewLine]", 
  "\t", 
  RowBox[{"N", "@", 
   RowBox[{"Total", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Cases", "[", "\[IndentingNewLine]", "\t\t\t", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Inactivate", "[", "form", "]"}], "\[IndentingNewLine]", 
             "\t\t", "/.", 
             RowBox[{
              RowBox[{"const_", "?", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Quiet", "@", 
                  RowBox[{"MemberQ", "[", 
                   RowBox[{
                    RowBox[{"Attributes", "[", "#", "]"}], ",", "Constant"}], 
                   "]"}]}], "&"}], ")"}]}], ":>", "1"}]}], 
            "\[IndentingNewLine]", "\t\t\t", "/.", 
            RowBox[{"c_Complex", ":>", 
             RowBox[{"ReIm", "[", "c", "]"}]}]}], "\[IndentingNewLine]", 
           "\t\t\t\t", "/.", 
           RowBox[{
            RowBox[{"r", ":", 
             RowBox[{"Rational", "[", 
              RowBox[{"i1_Integer", ",", "i2_Integer"}], "]"}]}], ":>", 
            RowBox[{"{", 
             RowBox[{"i1", ",", "i2"}], "}"}]}]}], "\[IndentingNewLine]", 
          "\t\t\t\t\t", "/.", 
          RowBox[{
           RowBox[{
            RowBox[{"Inactive", "[", "Sqrt", "]"}], "[", "arg_", "]"}], ":>", 
           
           RowBox[{"Inactive", "[", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"{", 
              RowBox[{"arg", ",", "arg"}], "}"}], "]"}], "]"}]}]}], 
         "\[IndentingNewLine]", "\t\t\t\t\t\t", "/.", 
         RowBox[{
          RowBox[{
          "Alternatives", "[", "\[IndentingNewLine]", "\t\t\t\t\t\t\t", 
           RowBox[{
            RowBox[{
             RowBox[{"Inactive", "[", "Power", "]"}], "[", 
             RowBox[{"b_", ",", 
              RowBox[{
               RowBox[{
                RowBox[{"Inactive", "[", "Times", "]"}], "[", 
                RowBox[{"m_", ",", 
                 RowBox[{
                  RowBox[{"Inactive", "[", "Power", "]"}], "[", 
                  RowBox[{"n_", ",", 
                   RowBox[{"-", "1"}]}], "]"}]}], "]"}], "|", 
               RowBox[{"{", 
                RowBox[{"m_", ",", "n_"}], "}"}]}]}], "]"}], ",", 
            "\[IndentingNewLine]", "\t\t\t\t\t\t\t", 
