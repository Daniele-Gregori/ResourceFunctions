       RowBox[{
        RowBox[{"x", "<=", "0"}], "&&", 
        RowBox[{"y", ">=", "0"}]}], ",", 
       RowBox[{"outn", "~", "Join", "~", "outp"}], ",", 
       RowBox[{
        RowBox[{"y", "<=", "0"}], "&&", 
        RowBox[{"x", ">=", "0"}]}], ",", 
       RowBox[{"outp", "~", "Join", "~", "outn"}]}], "]"}]}]}], 
