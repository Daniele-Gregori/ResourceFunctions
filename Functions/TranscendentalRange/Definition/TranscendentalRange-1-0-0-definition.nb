Cell[BoxData[{
 RowBox[{"ClearAll", "[", "test", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "test", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<Time\>\"", "->", "False"}], ",", 
      RowBox[{"\"\<Detail\>\"", "->", "False"}], ",", 
      RowBox[{"\"\<GeneratorsDomain\>\"", "->", "Rationals"}]}], "}"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"test", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f_", ",", "2"}], "}"}], ",", "x_", ",", "y_", ",", "z_", ",", 
     RowBox[{"opts", ":", 
      RowBox[{"OptionsPattern", "[", "test", "]"}]}]}], "]"}], ":=", 
   "\[IndentingNewLine]", "\t", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"default", ",", "testing", ",", "algGen"}], "}"}], ",", 
     "\[IndentingNewLine]", "\t\t", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"algGen", "=", 
       RowBox[{"OptionValue", "[", "\"\<GeneratorsDomain\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", "       ", "\[IndentingNewLine]", 
      RowBox[{"default", "=", 
       RowBox[{
        RowBox[{"TranscendentalRange", "[", 
         RowBox[{"x", ",", "y", ",", "z", ",", 
          RowBox[{"Method", "->", "f"}], ",", 
          RowBox[{"\"\<GeneratorsDomain\>\"", "->", "algGen"}]}], "]"}], "~", 
        "EchoTiming", "~", "\"\<smart\>\""}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
