Cell[BoxData[
 RowBox[{
  RowBox[{"coreRange", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", " ", ":", " ", "Power"}], ",", " ", "2"}], "}"}], ",", " ",
     "x_", ",", " ", "y_", ",", " ", 
    RowBox[{"z_", " ", ":", " ", "1"}], ",", " ", 
    RowBox[{"opt_String", " ", ":", " ", "\"\<Rational\>\""}]}], "]"}], " ", ":=",
   " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"fun", " ", "=", " ", 
       RowBox[{
        RowBox[{"#1", "^", "#2"}], " ", "&"}]}], ",", " ", 
      RowBox[{"min", " ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", " ", ">", " ", "0"}], ",", " ", "x", ",", " ", "y"}], 
        "]"}]}], ",", " ", 
      RowBox[{"max", " ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"z", " ", ">", " ", "0"}], ",", " ", "y", ",", " ", "x"}], 
        "]"}]}], ",", " ", "rc", ",", " ", "ra", ",", " ", "cs", ",", " ", 
      "as", ",", " ", "ncs", ",", " ", "nas", ",", " ", "outp", ",", " ", 
      "outn", ",", "\[IndentingNewLine]", 
      RowBox[{"turn", "=", 
       RowBox[{"turning", "[", 
        RowBox[{"Power", ",", "2"}], "]"}]}]}], "}"}], ",", "\n", "  ", "\n", 
    "  ", 
    RowBox[{
     RowBox[{"preprRange", "[", "\n", "   ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "y", ",", " ", "z", ",", " ", "opt"}], "}"}], ",",
        "\n", "   ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"{", "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"turn", ",", "0"}], "}"}]}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"domain", "[", "f", "]"}], ",", " ", "1", ",", " ", 
         RowBox[{"{", "}"}], ",", " ", 
         RowBox[{"{", "1", "}"}]}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{
        "rc", ",", " ", "ra", ",", " ", "cs", ",", " ", "as", ",", " ", "ncs",
          ",", " ", "nas"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", " ", 
     "\[IndentingNewLine]", "\n", 
     RowBox[{
      RowBox[{"cs", "[", "1", "]"}], "=", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"cs", "[", "1", "]"}], ",", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"Element", "[", 
           RowBox[{"#", ",", "Rationals"}], "]"}]}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"cs", "[", "2", "]"}], "=", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"cs", "[", "2", "]"}], ",", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"Element", "[", 
           RowBox[{"#", ",", "Rationals"}], "]"}]}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"cs", "[", "3", "]"}], "=", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"cs", "[", "3", "]"}], ",", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"Element", "[", 
           RowBox[{"#", ",", "Rationals"}], "]"}]}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"outp", " ", ":=", " ", "\[IndentingNewLine]", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"monotonicOuter", "[", 
           RowBox[{"fun", ",", " ", 
            RowBox[{"{", 
             RowBox[{"min", ",", " ", "max"}], "}"}], ",", 
            RowBox[{"as", "[", "1", "]"}], ",", " ", 
            RowBox[{"cs", "[", "3", "]"}], ",", "  ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", "1"}], "]"}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"monotonicOuter", "[", 
           RowBox[{"fun", ",", " ", 
            RowBox[{"{", 
             RowBox[{"min", ",", " ", "max"}], "}"}], ",", 
            RowBox[{"as", "[", "2", "]"}], ",", " ", 
            RowBox[{"cs", "[", "3", "]"}], ",", "  ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "1"}], "}"}], ",", " ", "1"}], "]"}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"monotonicOuter", "[", 
           RowBox[{"fun", ",", " ", 
            RowBox[{"{", 
