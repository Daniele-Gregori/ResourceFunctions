 RowBox[{
  RowBox[{"range", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_", ",", "opt_String"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Switch", "[", 
   RowBox[{
   "opt", ",", "\[IndentingNewLine]", "\t\t", "\"\<Rational\>\"", ",", 
    "\[IndentingNewLine]", "\t\t\t", 
    RowBox[{"Range", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "\[IndentingNewLine]", 
    "\t\t", "\"\<Algebraic\>\"", ",", "\[IndentingNewLine]", "\t\t\t", 
    RowBox[{"algebraicRange", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "\[IndentingNewLine]", 
    "\t\t", "\"\<RationalFarey\>\"", ",", "\[IndentingNewLine]", "\t\t\t", 
    RowBox[{"fareyRange", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", "\[IndentingNewLine]", 
    "\t\t", "\"\<AlgebraicFarey\>\"", ",", "\[IndentingNewLine]", "\t\t\t", 
    RowBox[{"algebraicRange", "[", 
     RowBox[{"x", ",", "y", ",", "z", ",", 
      RowBox[{"\"\<FareyRange\>\"", "->", "True"}]}], "]"}]}], 
   "]"}]}]], "Input",
