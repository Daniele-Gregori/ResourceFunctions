  "Source Sans Pro",ExpressionUUID->"dc5b9b35-ed86-483c-948a-7dd308eede01"],

Cell[TextData[{
 "gives all transcendental numbers of the forms ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", 
    RowBox[{"b", " ", 
     FormBox[
      SuperscriptBox["\[ExponentialE]", "a"],
      TraditionalForm]}]}], TraditionalForm]],ExpressionUUID->
  "42337954-7296-4cee-9ccf-d6b98563fdaa"],
 ", with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "<=", "t", "<=", "y"}], TraditionalForm]],ExpressionUUID->
