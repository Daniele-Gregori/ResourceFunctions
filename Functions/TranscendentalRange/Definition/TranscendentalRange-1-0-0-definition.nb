Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rooteq", "[", 
    RowBox[{"Power", ",", "2"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "x"}], ")"}], "^", "x"}], ",", "x"}], "]"}], "==", 
     "0"}], "//", "Simplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"turning", "[", 
    RowBox[{"Power", ",", "2"}], "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prec", "=", "1000"}], "}"}], ",", 
     RowBox[{
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"rooteq", "[", 
         RowBox[{"Power", ",", "2"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "0.1"}]}], "}"}], ",", 
        RowBox[{"PrecisionGoal", "->", "prec"}], ",", 
        RowBox[{"WorkingPrecision", "->", "prec"}]}], "]"}], "[", 
