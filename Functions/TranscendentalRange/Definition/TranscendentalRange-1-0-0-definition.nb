 RowBox[{
  RowBox[{
   RowBox[{"rooteq", "[", 
    RowBox[{"ArcCos", ",", "2"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         RowBox[{"ArcCos", "[", "x", "]"}]}], ",", "x"}], "]"}], "==", "0"}], 
     "//", "PowerExpand"}], "//", "Simplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"turning", "[", 
    RowBox[{"ArcCos", ",", "2"}], "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prec", "=", "1000"}], "}"}], ",", 
     RowBox[{
