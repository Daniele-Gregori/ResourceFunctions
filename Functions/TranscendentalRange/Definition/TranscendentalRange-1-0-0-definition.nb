 RowBox[{
  RowBox[{"(*", 
   RowBox[{"splitRange", ":", 
    RowBox[{
    "split", " ", "a", " ", "sorted", " ", "list", " ", "into", " ", 
     "segments", " ", "at", " ", "given", " ", "points"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", "splitRange", "]"}], "\n", 
   RowBox[{
    RowBox[{"splitRange", "[", 
     RowBox[{
     "list_List", ",", "splitPts_List", ",", "z_", ",", "segs_", ",", 
      "count_"}], "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"pts", ",", "bounds", ",", "n", ",", "seg"}], "}"}], ",", 
      RowBox[{
       RowBox[{"pts", "=", 
        RowBox[{"Sort", "[", "splitPts", "]"}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"bounds", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"-", "Infinity"}], "}"}], ",", "pts", ",", 
          RowBox[{"{", "Infinity", "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{
         RowBox[{"Length", "[", "bounds", "]"}], "-", "1"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"count", "=", "n"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"seg", "=", 
           RowBox[{"Select", "[", 
            RowBox[{"list", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"bounds", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "<=", "#", "<=", 
               RowBox[{"bounds", "[", 
