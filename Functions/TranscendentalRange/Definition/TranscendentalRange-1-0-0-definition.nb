 RowBox[{
  RowBox[{
   RowBox[{"rooteq", "[", 
    RowBox[{"ArcSech", ",", "2"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         RowBox[{"ArcSech", "[", "x", "]"}]}], ",", "x"}], "]"}], "==", "0"}],
      "//", "PowerExpand"}], "//", "Simplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"turning", "[", 
    RowBox[{"ArcSech", ",", "2"}], "]"}], "=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"prec", "=", "1000"}], "}"}], ",", 
     RowBox[{
      RowBox[{"FindRoot", "[", 
