Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SqrtBox["3"], " ", 
    RowBox[{"Tanh", "[", 
     SqrtBox["3"], "]"}]}], ",", 
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"Coth", "[", 
      FractionBox["4", "3"], "]"}]}], 
    SqrtBox["3"]], ",", 
   FractionBox[
    RowBox[{"3", " ", 
     RowBox[{"Cot", "[", "1", "]"}]}], "2"], ",", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"2", " ", 
      RowBox[{"ArcSinh", "[", "1", "]"}]}], 
     SqrtBox["3"]]}], ",", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "2"]}], " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"4", " ", 
        SqrtBox["2"]}], "3"]}]]}], ",", 
   RowBox[{
    FractionBox["3", "2"], " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      FractionBox[
       SqrtBox["3"], "2"]}]]}], ",", 
   RowBox[{
    SqrtBox["2"], " ", 
    RowBox[{"Csch", "[", 
     FractionBox[
      RowBox[{"4", " ", 
       SqrtBox["2"]}], "3"], "]"}]}], ",", 
