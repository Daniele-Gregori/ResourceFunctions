 RowBox[{
  RowBox[{"coreRange", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", ":", "ArcCos"}], ",", "2"}], "}"}], ",", "x_", ",", "y_", ",", 
    RowBox[{"z_", ":", "1"}], ",", 
    RowBox[{"opt_String", ":", "\"\<Rational\>\""}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
