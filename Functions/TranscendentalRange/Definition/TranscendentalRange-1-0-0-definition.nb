Cell[BoxData[
 RowBox[{
  RowBox[{"monotonicOuter", "[", 
   RowBox[{"fun_Function", ",", 
    RowBox[{"{", 
     RowBox[{"min_", ",", "max_"}], "}"}], ",", "ls1_List", ",", "ls2_List", ",", 
    RowBox[{"{", 
     RowBox[{"mi_", ",", "mj_"}], "}"}], ",", "sign_"}], "]"}], ":=", 
  "\[IndentingNewLine]", "\t", 
  RowBox[{
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "i", ",", "j", ",", "new", ",", "begin", ",", "end", ",", "rgQ", ",", 
       "outer"}], "}"}], ",", "\[IndentingNewLine]", "\t\t", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{
      RowBox[{"outer", "=", 
       RowBox[{"CreateDataStructure", "[", "\"\<DynamicArray\>\"", "]"}]}], ";",
       "\t\t\t\t", "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", 
      RowBox[{"For", "[", "\[IndentingNewLine]", "\t\t\t", 
       RowBox[{
        RowBox[{"Switch", "[", 
         RowBox[{"mi", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
          RowBox[{"i", "=", "1"}], ",", "\[IndentingNewLine]", "\t\t\t\t\t", 
          RowBox[{"-", "1"}], ",", 
          RowBox[{"i", "=", 
           RowBox[{"Length", "[", "ls1", "]"}]}]}], "]"}], ",", 
        "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{"Switch", "[", 
         RowBox[{"mi", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
          RowBox[{"i", "<=", 
           RowBox[{"Length", "[", "ls1", "]"}]}], ",", "\[IndentingNewLine]", 
          "\t\t\t\t\t", 
          RowBox[{"-", "1"}], ",", 
          RowBox[{"i", ">=", "1"}]}], "]"}], ",", "\[IndentingNewLine]", 
        "\t\t\t", 
        RowBox[{"Switch", "[", 
         RowBox[{"mi", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", "\t\t\t\t\t", 
          RowBox[{"-", "1"}], ",", 
          RowBox[{"i", "--"}]}], "]"}], ",", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{
         RowBox[{"begin", "=", "True"}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", "\t\t\t", 
         RowBox[{"end", "=", "False"}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", "\t\t\t", 
         RowBox[{
         "For", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t\t\t", 
          RowBox[{
           RowBox[{"Switch", "[", 
            RowBox[{
            "mj", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
             RowBox[{"j", "=", "1"}], ",", "\[IndentingNewLine]", 
             "\t\t\t\t\t", 
             RowBox[{"-", "1"}], ",", 
             RowBox[{"j", "=", 
              RowBox[{"Length", "[", "ls2", "]"}]}]}], "]"}], ",", 
           "\[IndentingNewLine]", "\t\t\t\t", 
           RowBox[{"Switch", "[", 
            RowBox[{
            "mj", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
             RowBox[{"j", "<=", 
              RowBox[{"Length", "[", "ls2", "]"}]}], ",", 
             "\[IndentingNewLine]", "\t\t\t\t\t", 
             RowBox[{"-", "1"}], ",", 
             RowBox[{"j", ">=", "1"}]}], "]"}], ",", "\[IndentingNewLine]", 
           "\t\t\t\t", 
           RowBox[{"Switch", "[", 
            RowBox[{
            "mj", ",", "\[IndentingNewLine]", "\t\t\t\t\t", "1", ",", 
             RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", "\t\t\t\t\t", 
             RowBox[{"-", "1"}], ",", 
             RowBox[{"j", "--"}]}], "]"}], ",", "\[IndentingNewLine]", 
           "\[IndentingNewLine]", "\t\t\t\t", "\[IndentingNewLine]", 
           "\[IndentingNewLine]", "\t\t\t\t", 
           RowBox[{
            RowBox[{"new", "=", 
             RowBox[{"fun", "[", 
              RowBox[{
               RowBox[{"ls1", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ",", 
               RowBox[{"ls2", "[", 
                RowBox[{"[", "j", "]"}], "]"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\t\t\t\t", "\[IndentingNewLine]", 
            "\t\t\t\t", 
            RowBox[{"rgQ", "=", 
             RowBox[{"min", "<=", "new", "<=", "max"}]}], ";", 
            "\[IndentingNewLine]", "\t\t\t\t", "\[IndentingNewLine]", 
            "\t\t\t\t", 
            RowBox[{"If", "[", 
             RowBox[{"rgQ", ",", "\[IndentingNewLine]", "\t\t\t\t\t", 
              RowBox[{"begin", "=", "False"}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t\t\t", 
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"new", ">", "max"}], "&&", 
               RowBox[{"sign", "===", "1"}]}], ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t\t", 
              RowBox[{"end", "=", "True"}], ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t", 
              RowBox[{
               RowBox[{"new", "<", "min"}], "&&", 
               RowBox[{"sign", "===", 
                RowBox[{"-", "1"}]}]}], ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t\t", 
              RowBox[{"end", "=", "True"}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t\t\t", "\[IndentingNewLine]", 
            "\t\t\t\t", 
            RowBox[{"Which", "[", "\[IndentingNewLine]", "\t\t\t\t\t", 
             RowBox[{
              RowBox[{"rgQ", "&&", 
               RowBox[{"!", "begin"}]}], ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t\t", 
              RowBox[{"outer", "[", 
               RowBox[{"\"\<Append\>\"", ",", "new"}], "]"}], ",", 
              "\[IndentingNewLine]", "\t\t\t\t\t", 
              RowBox[{"begin", "&&", 
               RowBox[{"!", "end"}]}], ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t\t", 
              RowBox[{"(*", 
               RowBox[{
               "this", " ", "should", " ", "be", " ", "avoided", " ", "with", 
                " ", "better", " ", "splitting"}], "*)"}], 
              "\[IndentingNewLine]", "\t\t\t\t\t\t", 
              RowBox[{
               RowBox[{"Echo", "[", 
                RowBox[{"{", 
                 RowBox[{"\"\<redundant\>\"", ",", 
                  RowBox[{"ls1", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], ",", 
                  RowBox[{"ls2", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], "}"}], "]"}], ";", 
               "\[IndentingNewLine]", "\t\t\t\t\t\t", 
               RowBox[{"Continue", "[", "]"}]}], ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t", "True", ",", "\[IndentingNewLine]", 
              "\t\t\t\t\t\t", 
              RowBox[{"Break", "[", "]"}]}], "]"}]}]}], "]"}]}]}], "]"}], ";",
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", 
      RowBox[{"Normal", "@", "outer"}]}]}], "]"}], "//", 
   "QuietEcho"}]}]], "Input",
