Cell[BoxData[
 RowBox[{
  RowBox[{"job", "=", 
   RowBox[{
   "RemoteBatchSubmit", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
     "CompoundExpression", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{
        RowBox[{"timesO", "=", 
         RowBox[{"{", "}"}]}], ";", 
        RowBox[{"timesA", "=", 
         RowBox[{"{", "}"}]}], ";", 
        RowBox[{"lens", "=", 
         RowBox[{"{", "}"}]}], ";", 
        RowBox[{"checks", "=", 
         RowBox[{"{", "}"}]}], ";"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Block", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
            "resO", ",", "resA", ",", "timeO", ",", "timeA", ",", "check", ",",
              "len"}], "}"}], ",", "\[IndentingNewLine]", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"timeO", ",", "resO"}], "}"}], "=", 
             RowBox[{
              RowBox[{"outerAlgebraicRange", "[", 
               RowBox[{"0", ",", "r", ",", 
                RowBox[{"1", "/", "2"}]}], "]"}], "//", "RepeatedTiming"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"timesO", ",", "timeO"}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"timeA", ",", "resA"}], "}"}], "=", 
             RowBox[{
              RowBox[{"AlgebraicRange", "[", 
               RowBox[{"0", ",", "r", ",", 
                RowBox[{"1", "/", "2"}]}], "]"}], "//", "RepeatedTiming"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"timesA", ",", "timeA"}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"check", "=", 
             RowBox[{"resO", "==", "resA"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"checks", ",", "check"}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"len", "=", 
             RowBox[{"Length", "[", "resA", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"lens", ",", "len"}], "]"}], ";"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"r", ",", "maxs"}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Bound\>\"", "->", "maxs"}], ",", 
         RowBox[{"\"\<Match\>\"", "->", "checks"}], ",", 
         RowBox[{"\"\<Length\>\"", "->", "lens"}], ",", 
         RowBox[{"\"\<Time Outer\>\"", "->", "timesO"}], ",", 
         RowBox[{"\"\<Time Actual\>\"", "->", "timesA"}]}], "|>"}]}], "]"}], ",",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"RemoteMachineClass", "->", "\"\<Basic4x16\>\""}]}], "]"}]}], 
  "\[IndentingNewLine]"}]], "Input",
