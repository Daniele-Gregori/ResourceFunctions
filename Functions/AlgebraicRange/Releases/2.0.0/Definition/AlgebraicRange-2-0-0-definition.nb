   RowBox[{"AlgebraicRange", "[", 
    RowBox[{
     StyleBox["x", "TI"], ",", 
     StyleBox["y", "TI"], ",", 
     StyleBox["s", "TI"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "3f19f3f1-6def-4f29-8b3a-8b7c7c412bda"],
 " for step parameter ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{"s", "!=", "1"}], TraditionalForm]],ExpressionUUID->
    "dc0c8415-24c3-429b-b4a2-d87879609c84"]],ExpressionUUID->
    "7d2aaae8-021f-443e-9160-06b088519cc1"], TraditionalForm]],ExpressionUUID->
  "63c53901-1509-4da3-b7fd-c8c7eaa1b511"],
 " is more easily conveyed in terms of ",
 ButtonBox["Outer",
  BaseStyle->"Link",
