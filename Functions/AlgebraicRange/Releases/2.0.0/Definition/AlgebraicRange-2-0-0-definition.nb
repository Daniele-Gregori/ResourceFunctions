        "CodeAssistant" -> True, "CodeWriter" -> True|>|>|>|>,
 CellChangeTimes->{{3.9692856498904257`*^9, 3.969285711454*^9}, {
   3.969285767625641*^9, 3.969285921879158*^9}, {3.969286261149523*^9, 
   3.969286264185863*^9}, {3.969286344928153*^9, 3.969286345633061*^9}, {
   3.9692863854658823`*^9, 3.969286387688382*^9}, {3.9692871307508287`*^9, 
