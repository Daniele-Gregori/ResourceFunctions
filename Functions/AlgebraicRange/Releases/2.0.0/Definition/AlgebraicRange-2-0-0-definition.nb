Cell[TextData[{
 "The step between successive algebraics is not straightforward to define \
univocally, as there exists no constant difference among the irrational \
numbers generated even with the elementary algebraic range. However, it turns \
out that an intuitively simple class of algebraic ranges, with non-unit step \
parameter ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "4e10e4f1-e774-4892-85b9-d8f05af62c90"],
 ", is obtained by taking the Outer product of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"AlgebraicRange", "[", 
    RowBox[{Cell[TextData[Cell[BoxData[
      FormBox[
       RowBox[{
        ButtonBox["Min",
         BaseStyle->"Link",
         ButtonData->"paclet:ref/Min"], "[", 
        StyleBox[
         RowBox[{"x", ",", 
          RowBox[{"x", "/", "s"}]}], "TI"], 
        StyleBox["]", "TI"]}], TraditionalForm]],ExpressionUUID->
      "a01e7cd8-8f16-4148-8aba-59673f9b3603"]],ExpressionUUID->
      "46c6acf9-81ef-46ba-9045-a90fe104535d"], ",", 
     StyleBox["y", "TI"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "553e290b-edcb-4b9b-bc1e-6603423e9328"],
 " with ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[Cell[TextData[Cell[BoxData[
      FormBox[
       RowBox[{
        ButtonBox["Join",
         BaseStyle->"Link",
         ButtonData->"paclet:ref/Join"], "[", 
        RowBox[{
         RowBox[{
          TagBox[
           ButtonBox[
            StyleBox["Range", "SymbolsRefLink",
             ShowStringCharacters->True,
             FontFamily->"Source Sans Pro"],
            BaseStyle->Dynamic[
              FEPrivate`If[
               CurrentValue["MouseOver"], {
               "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {
               "Link"}]],
            ButtonData->"paclet:ref/Range",
            ContentPadding->False],
           MouseAppearanceTag["LinkHand"]], "[", 
          RowBox[{"0", ",", 
           RowBox[{
            ButtonBox["Max",
             BaseStyle->"Link",
             ButtonData->"paclet:ref/Max"], "[", 
            RowBox[{"1", ",", " ", "s"}], "]"}], ",", " ", "s"}], "]"}], ",", 
         " ", 
         RowBox[{
          TagBox[
           ButtonBox[
            StyleBox["Range", "SymbolsRefLink",
             ShowStringCharacters->True,
             FontFamily->"Source Sans Pro"],
            BaseStyle->Dynamic[
              FEPrivate`If[
               CurrentValue["MouseOver"], {
               "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {
               "Link"}]],
            ButtonData->"paclet:ref/Range",
            ContentPadding->False],
           MouseAppearanceTag["LinkHand"]], "[", 
          RowBox[{
           RowBox[{
            ButtonBox["Max",
             BaseStyle->"Link",
             ButtonData->"paclet:ref/Max"], "[", 
            RowBox[{"1", ",", " ", Cell[TextData[Cell[BoxData[
              FormBox[Cell[TextData[Cell[BoxData[
                FormBox["s", TraditionalForm]],ExpressionUUID->
                "7723edf4-9502-47b2-a7ab-bef65d92599b"]],ExpressionUUID->
                "963702bf-dace-4308-8a23-b0d1b658866d"], TraditionalForm]],
              ExpressionUUID->"59614a8a-abbf-4df7-af31-ec27d60f0951"]],
              ExpressionUUID->"86739cd2-b573-4aae-a597-8e899f2a3287"]}], 
            "]"}], ",", " ", "y", ",", " ", "s"}], "]"}]}], "]"}], 
       TraditionalForm]],ExpressionUUID->
      "a4e3ced2-d5b1-4921-afef-0be7b71ba0d1"]],ExpressionUUID->
      "75e1e58d-d6ec-4714-85c2-23a041a3a4aa"], TraditionalForm]],
    ExpressionUUID->"d7e5daa8-5a96-4e02-99c5-c46d1312c1e3"]],ExpressionUUID->
    "1a3fbe5e-f5e6-42b8-82a8-40297018eb79"], TraditionalForm]],ExpressionUUID->
  "34814ebf-2836-414b-b299-179ac53ede0c"],
 ", for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", "s", "<=", 
    RowBox[{"y", "-", "x"}]}], TraditionalForm]],ExpressionUUID->
  "7b880c37-8701-44b5-93c7-fc472bdd0656"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", "x", "<=", "y"}], TraditionalForm]],ExpressionUUID->
  "4ab44efc-3691-4970-86d0-fa3929b4cd50"],
 ". Then the parameter ",
 Cell[BoxData[
  FormBox[
   StyleBox["s", "TI"], TraditionalForm]],ExpressionUUID->
  "bdb4c3c7-9c6a-48ee-a46d-4c2891492dd2"],
 " also becomes the upper bound for all the steps. For example, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"AlgebraicRange", "[", 
     RowBox[{"0", ",", "2", ",", 
      FormBox[
       FormBox[
        FractionBox["1", "2"],
        TraditionalForm],
       TraditionalForm]}], "]"}], "=", 
    RowBox[{
     FormBox[
      FormBox[
       RowBox[{"{", 
        RowBox[{"0", ",", 
         FractionBox["1", "2"], ",", 
         FractionBox["1", 
          SqrtBox["2"]], ",", 
         FractionBox[
          SqrtBox["3"], "2"], ",", "1", ",", 
         SqrtBox["2"], ",", 
         FractionBox["3", "2"], ",", 
         SqrtBox["3"], ",", "2"}], "}"}],
       TraditionalForm],
      TraditionalForm], "."}]}], TraditionalForm]],ExpressionUUID->
  "cc4f8a92-79b9-4e7a-8bd8-003bbf9dc161"]
}], "Notes",
