Cell[BoxData[
 RowBox[{
  RowBox[{"failureThrow", "[", "arg_", "]"}], ":=", "\n", "\t", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"MemberQ", "[", 
     RowBox[{"arg", ",", 
      RowBox[{"_Failure", "|", "$Failed"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}], ",", "\n", "\t\t", 
    RowBox[{"Throw", "@", 
     RowBox[{"First", "@", 
      RowBox[{"Union", "@", 
       RowBox[{"Cases", "[", 
        RowBox[{"arg", ",", 
         RowBox[{"_Failure", "|", "$Failed"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}]}]}]}], ",", "\n", 
    "\t\t", "arg"}], "]"}]}]], "Input",
