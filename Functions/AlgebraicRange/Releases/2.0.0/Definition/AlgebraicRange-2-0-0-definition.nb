Cell[BoxData[{
 RowBox[{"ClearAll", "[", "fareyRange", "]"}], "\n", 
 RowBox[{
  RowBox[{"fareyRange", "[", 
   RowBox[{"r1_", ",", "r2_", ",", "r3_"}], "]"}], ":=", "\n", "\t", 
  RowBox[{"Which", "[", "\n", "\t\t", 
   RowBox[{
    RowBox[{"r3", ">=", "1"}], ",", "\n", "\t\t\t", 
    RowBox[{
     RowBox[{"ResourceFunction", "[", "\"\<FareyRange\>\"", "]"}], "[", 
     RowBox[{"r1", ",", "r2", ",", "r3"}], "]"}], ",", "\n", "\t\t", 
