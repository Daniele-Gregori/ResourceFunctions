Cell[TextData[{
 "The option \"StepMethod\" can be used to define the step in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"AlgebraicRange", "[", 
    RowBox[{
     StyleBox["x", "TI"], ",", 
     StyleBox["y", "TI"], ",", 
     StyleBox["s", "TI"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "0af6e02d-c1dd-4722-8d49-d9eaff58c57c"],
 " and can take the following values, for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", "x", "<=", "y"}], TraditionalForm]],ExpressionUUID->
  "be512777-aba0-400c-a078-bbd2e740ad8e"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", "s", "<=", 
    RowBox[{"y", "-", "x"}]}], TraditionalForm]],ExpressionUUID->
  "46655ac8-de71-42ca-bdce-1cc61e34b580"],
 ":"
}], "Notes",
