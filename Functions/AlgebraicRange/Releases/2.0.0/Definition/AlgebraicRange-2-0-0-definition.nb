Cell[BoxData[{
 RowBox[{"ClearAll", "[", "stepSelect", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"stepSelect", "[", 
    RowBox[{"list_List", ",", "d_"}], "]"}], ":=", "\[IndentingNewLine]", 
   "\t", 
   RowBox[{
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sel", ",", "eln", ",", "i"}], "}"}], ",", 
      "\[IndentingNewLine]", "\t\t", 
      RowBox[{
       RowBox[{"sel", "=", 
        RowBox[{"CreateDataStructure", "[", "\"\<DynamicArray\>\"", "]"}]}], ";",
        "\[IndentingNewLine]", "\t\t", 
       RowBox[{"eln", "=", 
        RowBox[{"list", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", "\t\t", 
       RowBox[{"sel", "[", 
        RowBox[{"\"\<Append\>\"", ",", "eln"}], "]"}], ";", 
       "\[IndentingNewLine]", "\t", "\[IndentingNewLine]", "\t\t", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "2"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{"Length", "[", "list", "]"}]}], ",", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", "\t\t\t", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"list", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", "eln"}], "]"}], ">=", 
            "d"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
           "\t\t\t\t", 
           RowBox[{
            RowBox[{"eln", "=", 
             RowBox[{"list", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            "\t\t\t\t", 
            RowBox[{"sel", "[", 
             RowBox[{"\"\<Append\>\"", ",", "eln"}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t\t\t", 
            RowBox[{"Continue", "[", "]"}]}]}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\t\t", 
       RowBox[{"sel", "//", "Normal"}]}]}], "]"}], "~", "Quiet", "~", 
    RowBox[{"N", "::", "meprec"}]}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
