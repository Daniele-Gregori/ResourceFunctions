Cell[BoxData[
 RowBox[{
  RowBox[{"testARbounds", "[", 
   RowBox[{"x_", ",", "y_", ",", 
    RowBox[{"ID_", ":", "\"\<\>\""}], ",", 
    RowBox[{"ord_", ":", "2"}]}], "]"}], ":=", "\[IndentingNewLine]", "\t", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"input", ",", "expected", ",", "test"}], "}"}], ",", 
    "\[IndentingNewLine]", "\t\t", 
    RowBox[{
     RowBox[{"input", "=", 
      RowBox[{"AR", "[", 
       RowBox[{"x", ",", "y", ",", 
        RowBox[{"\"\<RootOrder\>\"", "->", "ord"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"expected", "=", "\[IndentingNewLine]", "\t\t\t", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Which", "[", "\[IndentingNewLine]", "\t\t\t\t", 
         RowBox[{
          RowBox[{"0", "<=", "x", "<=", "y"}], ",", 
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{
             SuperscriptBox["x", "ord"], ",", 
             SuperscriptBox["y", "ord"]}], "]"}], "^", 
           RowBox[{"(", 
            RowBox[{"1", "/", "ord"}], ")"}]}], ",", "\[IndentingNewLine]", 
          "\t\t\t\t", 
          RowBox[{"x", "\[LessEqual]", "y", "\[LessEqual]", "0"}], ",", 
          RowBox[{"-", 
           RowBox[{
            RowBox[{"Range", "[", 
             RowBox[{
              SuperscriptBox["x", "ord"], ",", 
              SuperscriptBox["y", "ord"], ",", 
              RowBox[{"-", "1"}]}], "]"}], "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "ord"}], ")"}]}]}], ",", "\[IndentingNewLine]",
           "\t\t\t\t", 
          RowBox[{"x", ">", "y"}], ",", 
          RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t\t\t", 
          RowBox[{
           RowBox[{"x", "<", "0"}], "&&", 
           RowBox[{"y", ">", "0"}]}], ",", 
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"elrg1", ",", "elrg2"}], "}"}], ",", 
            "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t", 
            RowBox[{
             RowBox[{"elrg1", "=", 
              RowBox[{"-", 
               RowBox[{
                RowBox[{"Range", "[", 
                 RowBox[{
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{"-", "x"}], ")"}], "ord"], ",", "0", ",", 
                  RowBox[{"-", "1"}]}], "]"}], "^", 
                RowBox[{"(", 
                 RowBox[{"1", "/", "ord"}], ")"}]}]}]}], ";", 
             "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t", 
             RowBox[{"elrg2", "=", 
              RowBox[{
               RowBox[{"Range", "[", 
                RowBox[{"0", ",", 
                 SuperscriptBox["y", "ord"]}], "]"}], "^", 
               RowBox[{"(", 
                RowBox[{"1", "/", "ord"}], ")"}]}]}], ";", 
             "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"IntegerQ", "[", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{"-", "x"}], ")"}], "ord"], "]"}], "&&", 
                RowBox[{"IntegerQ", "[", 
                 SuperscriptBox["y", "ord"], "]"}], "&&", 
                RowBox[{
                 RowBox[{"Length", "[", "elrg1", "]"}], ">", "0"}], "&&", 
                RowBox[{
                 RowBox[{"Length", "[", "elrg2", "]"}], ">", "0"}]}], ",", 
               "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t\t", 
               RowBox[{"Join", "[", 
                RowBox[{"elrg1", ",", 
                 RowBox[{"Drop", "[", 
                  RowBox[{"elrg2", ",", "1"}], "]"}]}], "]"}], ",", 
               "\[IndentingNewLine]", "\t\t\t\t\t\t\t\t\t", 
               RowBox[{"Join", "[", 
                RowBox[{"elrg1", ",", "elrg2"}], "]"}]}], "]"}]}]}], "]"}]}], 
         "]"}], ",", 
        RowBox[{
         RowBox[{"x", "<=", "#", "<=", "y"}], "&"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"test", "=", 
      RowBox[{"VerificationTest", "[", "\[IndentingNewLine]", "\t\t\t\t", 
       RowBox[{
       "input", ",", "expected", ",", "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{"TestID", "->", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", "\t\t\t\t\t\t", 
           RowBox[{
            RowBox[{"ToString", "[", "gr", "]"}], ",", "\[IndentingNewLine]", 
            "\t\t\t\t\t\t", 
            RowBox[{"FromLetterNumber", "[", 
             RowBox[{"PreIncrement", "@", "id"}], "]"}], ",", 
            "\[IndentingNewLine]", "\t\t\t\t\t\t", "ID"}], "}"}], "~", 
          "StringRiffle", "~", "\"\<-\>\""}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"Echo", "[", 
      RowBox[{"input", ",", "\"\<input\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "\t\t", "test"}]}], "]"}]}]], "Input",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
     "ServiceDefaultModel" -> <|
      "LLMKit" -> Automatic, "OpenAI" -> "claude-opus-4-6", "Anthropic" -> 
