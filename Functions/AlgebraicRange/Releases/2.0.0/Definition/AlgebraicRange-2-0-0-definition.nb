Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"AlgebraicRange", ",", "iAlgebraicRange"}], "]"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "AlgebraicRange", "]"}], "=", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<RootOrder\>\"", "->", "2"}], ",", 
      RowBox[{"\"\<FareyRange\>\"", "->", "False"}], ",", 
      RowBox[{"WorkingPrecision", "->", "MachinePrecision"}], ",", 
      RowBox[{"\"\<FormulaComplexity\>\"", "->", "Infinity"}], ",", 
      RowBox[{"\"\<StepMethod\>\"", "->", "\"\<Outer\>\""}], ",", 
      RowBox[{"\"\<AlgebraicsOnly\>\"", "->", "True"}]}], "}"}]}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{"internal", " ", "main", " ", "function"}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"iAlgebraicRange", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ord_", "?", "NumericQ"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r1_", ",", "r2_", ",", 
        RowBox[{"r3_", ":", "1"}]}], "}"}], ",", 
      RowBox[{"d_", ":", "0"}], ",", 
      RowBox[{"opts", ":", 
       RowBox[{"OptionsPattern", "[", "AlgebraicRange", "]"}]}]}], "]"}], "/;",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ord", ">=", "1"}], "&&", 
     RowBox[{"NumericQ", "[", "r3", "]"}], "&&", 
     RowBox[{"d", ">=", "0"}]}]}], ":=", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\t", 
   RowBox[{
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "o", ",", "x", ",", "y", ",", "s", ",", "mainrange", ",", 
        "fullrange"}], "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"o", ",", "x", ",", "y", ",", "s"}], "}"}], "=", 
        RowBox[{"realReplace", "/@", 
         RowBox[{"{", 
          RowBox[{"ord", ",", "r1", ",", "r2", ",", "r3"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"Element", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"o", ",", "x", ",", "y", ",", "s"}], "}"}], ",", 
            "Reals"}], "]"}]}], ",", "\[IndentingNewLine]", "\t\t", 
         RowBox[{
          RowBox[{"Failure", "[", 
           RowBox[{"\"\<NotReal\>\"", ",", "\[IndentingNewLine]", "\t\t", 
            RowBox[{"failureNotReal", "[", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"o", ",", "x", ",", "y", ",", "s"}], "}"}], ",", 
               RowBox[{
                RowBox[{"!", 
                 RowBox[{"Element", "[", 
                  RowBox[{"#", ",", "Reals"}], "]"}]}], "&"}]}], "]"}], 
             "]"}]}], "]"}], "//", "failureThrow"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"Element", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"o", ",", "x", ",", "y", ",", "s"}], "}"}], ",", 
             "Algebraics"}], "]"}]}], "&&", 
          RowBox[{"OptionValue", "[", "\"\<AlgebraicsOnly\>\"", "]"}]}], ",", 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{
          RowBox[{"Failure", "[", 
           RowBox[{"\"\<NotAlgebraic\>\"", ",", "\[IndentingNewLine]", "\t\t", 
            RowBox[{"failureNotAlg", "[", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"o", ",", "x", ",", "y", ",", "s"}], "}"}], ",", 
               RowBox[{
                RowBox[{"!", 
                 RowBox[{"Element", "[", 
                  RowBox[{"#", ",", "Algebraics"}], "]"}]}], "&"}]}], "]"}], 
             "]"}]}], "]"}], "//", "failureThrow"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"d", ">", 
          RowBox[{"Abs", "[", "r3", "]"}]}], ",", "\[IndentingNewLine]", 
         "\t\t", 
         RowBox[{
          RowBox[{"failureUpperBound", "[", 
           RowBox[{"r3", ",", "d"}], "]"}], "//", "failureThrow"}]}], "]"}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"OptionValue", "[", "\"\<FareyRange\>\"", "]"}], "&&", 
          RowBox[{"IntegerQ", "[", "s", "]"}]}], ",", "\[IndentingNewLine]", 
         "\t\t", 
         RowBox[{"s", "=", 
          RowBox[{"1", "/", "s"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"mainrange", "=", "\[IndentingNewLine]", "\t\t", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", 
              RowBox[{"-", "1"}]}], "}"}], ",", "r3"}], "]"}], ",", 
          "\[IndentingNewLine]", "\t\t\t", 
          RowBox[{"elemRange", "[", 
           RowBox[{
            RowBox[{"{", "o", "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y", ",", "r3"}], "}"}], ",", "opts"}], "]"}], 
          ",", "\[IndentingNewLine]", "\t\t\t", 
          RowBox[{"stepRange", "[", 
           RowBox[{
            RowBox[{"{", "o", "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y", ",", "s"}], "}"}], ",", "opts"}], "]"}]}],
          "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
       RowBox[{"fullrange", "=", "mainrange"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "in", " ", "the", " ", "extended", " ", "paclet", " ", "version", " ",
          "here", " ", "combinations", " ", "of", " ", "the", " ", "basic", " ",
          "range", " ", "are", " ", "made"}], "*)"}], "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"restrictRange", "[", "\[IndentingNewLine]", "\t\t", 
         RowBox[{"fullrange", ",", "\[IndentingNewLine]", "\t\t", 
          RowBox[{"OptionValue", "[", "\"\<FormulaComplexity\>\"", "]"}], ",",
           "d", ",", 
          RowBox[{"OptionValue", "[", "WorkingPrecision", "]"}]}], "]"}], "//",
         "failureThrow"}]}]}], "]"}], "//", "Catch"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"iAlgebraicRange", "[", 
     RowBox[{"ordL_List", ",", "rL_List", ",", 
      RowBox[{"d_", ":", "0"}], ",", 
      RowBox[{"opts", ":", 
       RowBox[{"OptionsPattern", "[", "AlgebraicRange", "]"}]}]}], "]"}], "/;", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "ordL", "]"}], ">=", "2"}], "&&", 
      RowBox[{"d", ">=", "0"}]}], ")"}]}], ":=", "\[IndentingNewLine]", "\t", 
   
   RowBox[{
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"stepNegQ", ",", "join", ",", "sort"}], "}"}], ",", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"stepNegQ", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "rL", "]"}], "==", "3"}], "&&", 
         RowBox[{
          RowBox[{"rL", "[", 
           RowBox[{"[", "3", "]"}], "]"}], "<", "0"}]}]}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"join", "=", 
        RowBox[{"Join", "@@", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"failureThrow", "@", 
             RowBox[{"iAlgebraicRange", "[", 
              RowBox[{
               RowBox[{"{", "#", "}"}], ",", "rL", ",", "d", ",", "opts"}], 
              "]"}]}], "&"}], ",", "ordL"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"sort", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{"stepNegQ", ",", 
            RowBox[{"Reverse", "[", "#", "]"}], ",", "#"}], "]"}], "&"}], "@", 
         RowBox[{"cleanSort", "[", 
          RowBox[{"join", ",", 
           RowBox[{"OptionValue", "[", "WorkingPrecision", "]"}]}], "]"}]}]}],
        ";", "\[IndentingNewLine]", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"d", "!=", "0"}], ",", 
         RowBox[{"stepSelect", "[", 
          RowBox[{"sort", ",", "d"}], "]"}], ",", "sort"}], "]"}]}]}], "]"}], 
    "//", "Catch"}]}], "\n"}], "\n", 
 RowBox[{
