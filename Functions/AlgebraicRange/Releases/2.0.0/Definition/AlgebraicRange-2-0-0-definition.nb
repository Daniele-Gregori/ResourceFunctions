Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"outerAlgebraicRange", "[", 
    RowBox[{"x_", ",", "y_", ",", "s_"}], "]"}], "/;", 
   RowBox[{
    RowBox[{"x", "<=", "y"}], " ", "&&", " ", 
    RowBox[{"0", "<", "s", "<=", 
     RowBox[{"y", "-", "x"}]}]}]}], ":=", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Select", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"SortBy", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Outer", "[", "\[IndentingNewLine]", 
         RowBox[{"Times", ",", "\[IndentingNewLine]", 
          RowBox[{"Join", "[", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"Range", "[", 
             RowBox[{"0", ",", 
              RowBox[{"Max", "[", 
               RowBox[{"1", ",", "s"}], "]"}], ",", "s"}], "]"}], ",", 
            "\[IndentingNewLine]", "\t", 
            RowBox[{"Range", "[", 
             RowBox[{
              RowBox[{"Max", "[", 
               RowBox[{"1", ",", "s"}], "]"}], ",", 
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{"Abs", "[", "x", "]"}], ",", 
                RowBox[{"Abs", "[", "y", "]"}]}], "]"}], ",", "s"}], "]"}]}], 
           "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"AlgebraicRange", "[", "\[IndentingNewLine]", "\t", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"x", ">", "0"}], ",", 
              RowBox[{"Min", "[", 
               RowBox[{"x", ",", 
                RowBox[{"x", "/", "s"}]}], "]"}], ",", 
              RowBox[{"Max", "[", 
               RowBox[{"x", ",", 
                RowBox[{"x", "/", "s"}]}], "]"}]}], "]"}], ",", 
            "\[IndentingNewLine]", "\t", "y"}], "]"}]}], "]"}], 
        "\[IndentingNewLine]", "\t\t", "//", "Flatten"}], ",", 
       "\[IndentingNewLine]", "\t", "N"}], "]"}], ",", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"x", "<=", "#", "<=", "y"}], "&"}]}], "]"}], "//", 
   "\[IndentingNewLine]", "\t", 
   RowBox[{"DeleteDuplicatesBy", "[", "N", "]"}]}]}]], "Input",
