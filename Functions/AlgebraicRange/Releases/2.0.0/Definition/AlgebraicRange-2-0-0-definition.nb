   3.970330334787361*^9}},ExpressionUUID->"e0ac0fdb-ded4-4b83-b25e-\
39036e7c9ec8"],

Cell[TextData[{
 "If no step parameter is specified, the elementary algebraic range ",
 Cell[BoxData[
  FormBox[
   RowBox[{"AlgebraicRange", "[", 
    RowBox[{
     StyleBox["x", "TI"], ",", 
     StyleBox["y", "TI"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "faa7f26b-e489-4000-8b3c-6d40c889f9dd"],
 " is determined by the square root range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TagBox[
      ButtonBox[
       StyleBox["Sqrt", "SymbolsRefLink",
        ShowStringCharacters->True,
        FontFamily->"Source Sans Pro"],
       BaseStyle->Dynamic[
         FEPrivate`If[
          CurrentValue["MouseOver"], {
          "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
       
       ButtonData->"paclet:ref/Sqrt",
       ContentPadding->False],
      MouseAppearanceTag["LinkHand"]], "[", 
     RowBox[{
      TagBox[
       ButtonBox[
        StyleBox["Range", "SymbolsRefLink",
         ShowStringCharacters->True,
         FontFamily->"Source Sans Pro"],
        BaseStyle->Dynamic[
          FEPrivate`If[
           CurrentValue["MouseOver"], {
           "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
        ButtonData->"paclet:ref/Range",
        ContentPadding->False],
       MouseAppearanceTag["LinkHand"]], "[", 
      RowBox[{
       RowBox[{
        StyleBox["x", "TI"], "^", "2"}], ",", 
       RowBox[{
        StyleBox["y", "TI"], "^", "2"}]}], "]"}], "]"}], ","}], 
   TraditionalForm]],ExpressionUUID->"5211e74d-e114-4361-aadd-b2144b0f493e"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", 
    RowBox[{"y", ">", "0"}]}], TraditionalForm]],ExpressionUUID->
  "977e0e8c-46f1-4aa7-97f8-8e34944d8c5e"],
 ". The extension to negative bounds ",
 Cell[BoxData[
  FormBox[
  Cell["x <0",ExpressionUUID->"d3e1cf1a-fc61-443f-9767-cffd7cca83c0"], 
   TraditionalForm]],ExpressionUUID->"b5093f26-4527-4271-a4de-58ec52683952"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "<", "0"}], TraditionalForm]],ExpressionUUID->
  "bc200834-0977-4dc3-acdd-64090099862e"],
 " is performed simply by reflection, since general real roots are \
mathematically defined only for positive arguments."
}], "Notes",
 TaggingRules-><|
