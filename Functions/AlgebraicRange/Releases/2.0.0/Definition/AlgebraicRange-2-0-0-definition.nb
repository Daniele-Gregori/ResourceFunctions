Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"formulaComplexity", ",", "formulaComplexityHeuristic"}], "]"}], 
  "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"the", " ", "built"}], "-", 
    RowBox[{
    "in", " ", "methods", " ", "SimplifyCount", " ", "and", " ", "LeafCount", 
     " ", "have", " ", "the", " ", "disadvantage", " ", "of", " ", "not", " ",
      "being", " ", "continuous", " ", "and", " ", "thus", " ", "of", " ", 
     "not", " ", "allowing", " ", "fine", " ", "tuning", " ", "of", " ", 
     "the", " ", "output"}]}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"digitSum", "[", "int_Integer", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"$VersionNumber", ">=", "14"}], ",", 
     RowBox[{"DigitSum", "[", "int", "]"}], ",", 
     RowBox[{"Total", "@", 
      RowBox[{"IntegerDigits", "[", "int", "]"}]}]}], "]"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"formulaComplexityHeuristic", "[", 
    RowBox[{"form_", "?", "NumericQ"}], "]"}], ":=", "\n", "\t", 
   RowBox[{"N", "@", 
    RowBox[{"Total", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Cases", "[", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Inactivate", "[", "form", "]"}], "\n", "\t\t", "/.", 
              RowBox[{
               RowBox[{"const_", "?", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"Quiet", "@", 
                   RowBox[{"MemberQ", "[", 
                    RowBox[{
                    RowBox[{"Attributes", "[", "#", "]"}], ",", "Constant"}], 
                    "]"}]}], "&"}], ")"}]}], ":>", "1"}]}], "\n", "\t\t\t", "/.", 
             RowBox[{"c_Complex", ":>", 
              RowBox[{"ReIm", "[", "c", "]"}]}]}], "\n", "\t\t\t\t", "/.", 
            RowBox[{
             RowBox[{"r", ":", 
              RowBox[{"Rational", "[", 
               RowBox[{"i1_Integer", ",", "i2_Integer"}], "]"}]}], ":>", 
             RowBox[{"{", 
              RowBox[{"i1", ",", "i2"}], "}"}]}]}], "\n", "\t\t\t\t\t", "/.", 
           
           RowBox[{
            RowBox[{
             RowBox[{"Inactive", "[", "Sqrt", "]"}], "[", "arg_", "]"}], ":>", 
            RowBox[{"Inactive", "[", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"{", 
               RowBox[{"arg", ",", "arg"}], "}"}], "]"}], "]"}]}]}], "\n", 
          "\t\t\t\t\t\t", "/.", 
          RowBox[{
           RowBox[{"Alternatives", "[", "\n", "\t\t\t\t\t\t\t", 
            RowBox[{
             RowBox[{
              RowBox[{"Inactive", "[", "Power", "]"}], "[", 
              RowBox[{"b_", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"Inactive", "[", "Times", "]"}], "[", 
                 RowBox[{"m_", ",", 
                  RowBox[{
                   RowBox[{"Inactive", "[", "Power", "]"}], "[", 
                   RowBox[{"n_", ",", 
                    RowBox[{"-", "1"}]}], "]"}]}], "]"}], "|", 
                RowBox[{"{", 
                 RowBox[{"m_", ",", "n_"}], "}"}]}]}], "]"}], ",", "\n", 
             "\t\t\t\t\t\t\t", 
             RowBox[{
              RowBox[{"Inactive", "[", "Power", "]"}], "[", 
              RowBox[{
               RowBox[{"{", "b_", "}"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"Inactive", "[", "Times", "]"}], "[", 
                 RowBox[{"m_", ",", 
                  RowBox[{
                   RowBox[{"Inactive", "[", "Power", "]"}], "[", 
                   RowBox[{"n_", ",", 
                    RowBox[{"-", "1"}]}], "]"}]}], "]"}], "|", 
                RowBox[{"{", 
                 RowBox[{"m_", ",", "n_"}], "}"}]}]}], "]"}]}], "]"}], ":>", 
           "\n", "\t\t\t\t\t\t\t\t", 
           RowBox[{"Table", "[", 
            RowBox[{"b", ",", 
             RowBox[{
              RowBox[{"Abs", "[", "n", "]"}], "+", 
              RowBox[{"Abs", "[", "m", "]"}]}]}], "]"}]}]}], ",", "\n", 
         "\t\t\t", "_Integer", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}], "/.", " ", 
       RowBox[{
        RowBox[{"j_Integer", "?", "NonPositive"}], ":>", 
        RowBox[{
         RowBox[{"-", "j"}], "+", "1"}]}]}], "\n", "\t\t\t\t", "/.", 
      RowBox[{"i_Integer", ":>", 
       RowBox[{"Mean", "[", 
        RowBox[{
         RowBox[{"1", "/", "2"}], 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"5", 
            RowBox[{"IntegerLength", "[", "i", "]"}]}], ",", 
           RowBox[{"digitSum", "[", "i", "]"}], ",", 
           RowBox[{"Total", "[", 
            RowBox[{"Last", "/@", 
             RowBox[{"FactorInteger", "[", "i", "]"}]}], "]"}], ",", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Abs", "[", 
             RowBox[{"N", "[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}]}],
      "]"}]}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"formulaComplexity", "[", 
   RowBox[{"form_", "?", "NumericQ"}], "]"}], ":=", "\n", "\t", 
  RowBox[{"formulaComplexityHeuristic", "[", "form", "]"}], 
  "\t\t"}]}], "Input",
