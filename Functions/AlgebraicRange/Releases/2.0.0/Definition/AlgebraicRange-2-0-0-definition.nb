Cell[TextData[{
 "AlgebraicRange creates ranges made of ",
 ButtonBox["algebraic",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Algebraics"],
 " numbers. This extends the basic concept of ",
 ButtonBox["Range",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Range"],
 " to include, besides ",
 ButtonBox["Rational",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Rationals"],
 " numbers, also roots, always restricted to the ",
 ButtonBox["Reals",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Reals"],
 " domain."
}], "Notes",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
