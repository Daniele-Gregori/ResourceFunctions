Cell[BoxData[
 RowBox[{
  RowBox[{"testARstep", "[", 
   RowBox[{"x_", ",", "y_", ",", "s_", ",", 
    RowBox[{"ID_", ":", "\"\<\>\""}], ",", 
    RowBox[{"ord_", ":", "2"}]}], "]"}], ":=", "\[IndentingNewLine]", "\t", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"input", ",", "expected", ",", "test", ",", "diff"}], "}"}], ",",
     "\[IndentingNewLine]", "\t\t", 
    RowBox[{
     RowBox[{"input", "=", 
      RowBox[{"AR", "[", 
       RowBox[{"x", ",", "y", ",", "s", ",", 
        RowBox[{"\"\<RootOrder\>\"", "->", "ord"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"expected", "=", "\[IndentingNewLine]", "\t\t\t", 
      RowBox[{"Which", "[", "\[IndentingNewLine]", "\t\t\t\t", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "<=", "y"}], "&&", 
         RowBox[{"s", ">", "0"}], "&&", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "<", "0"}], "&&", 
            RowBox[{"y", ">=", "0"}]}], ",", 
           RowBox[{"s", "<=", 
            RowBox[{"y", "-", "x"}]}], ",", "True"}], "]"}]}], ",", 
        "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"SortBy", "[", "\[IndentingNewLine]", "\t\t\t\t", 
            RowBox[{
             RowBox[{
              RowBox[{"Outer", "[", 
               RowBox[{"Times", ",", "\[IndentingNewLine]", "\t\t\t\t", 
                RowBox[{"Join", "[", 
                 RowBox[{
                  RowBox[{"Range", "[", 
                   RowBox[{"0", ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{"1", ",", "s"}], "]"}], ",", "s"}], "]"}], ",", 
                  RowBox[{"Range", "[", 
                   RowBox[{
                    RowBox[{"Max", "[", 
                    RowBox[{"1", ",", "s"}], "]"}], ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{
                    RowBox[{"Abs", "[", "x", "]"}], ",", 
                    RowBox[{"Abs", "[", "y", "]"}]}], "]"}], ",", "s"}], 
                   "]"}]}], "]"}], ",", "\[IndentingNewLine]", "\t\t\t\t", 
                RowBox[{"AR", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"x", ">", "0"}], ",", 
                    RowBox[{"Min", "[", 
                    RowBox[{"x", ",", 
                    RowBox[{"x", "/", "s"}]}], "]"}], ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{"x", ",", 
                    RowBox[{"x", "/", "s"}]}], "]"}]}], "]"}], ",", "y", ",", 
                  
                  RowBox[{"\"\<RootOrder\>\"", "->", "ord"}]}], "]"}]}], 
               "]"}], "\[IndentingNewLine]", "\t\t\t\t\t", "//", "Flatten"}], 
             ",", "N"}], "]"}], ",", "\[IndentingNewLine]", "\t\t\t\t\t", 
           RowBox[{
            RowBox[{"x", "<=", "#", "<=", "y"}], "&"}]}], "]"}], "//", 
         RowBox[{"DeleteDuplicatesBy", "[", "N", "]"}]}], ",", 
        "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{
         RowBox[{"x", ">=", "y"}], "&&", 
         RowBox[{"s", "<", "0"}], "&&", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "<", "0"}], "&&", 
            RowBox[{"x", ">=", "0"}]}], ",", 
           RowBox[{
            RowBox[{"-", "s"}], "<=", 
            RowBox[{"x", "-", "y"}]}], ",", "True"}], "]"}]}], ",", 
        "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"ReverseSortBy", "[", "\[IndentingNewLine]", "\t\t\t\t", 
            RowBox[{
             RowBox[{
              RowBox[{"Outer", "[", 
               RowBox[{"Times", ",", "\[IndentingNewLine]", "\t\t\t\t", 
                RowBox[{"Join", "[", 
                 RowBox[{
                  RowBox[{"Range", "[", 
                   RowBox[{"0", ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{"1", ",", 
                    RowBox[{"-", "s"}]}], "]"}], ",", 
                    RowBox[{"-", "s"}]}], "]"}], ",", 
                  RowBox[{"Range", "[", 
                   RowBox[{
                    RowBox[{"Max", "[", 
                    RowBox[{"1", ",", 
                    RowBox[{"-", "s"}]}], "]"}], ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{
                    RowBox[{"Abs", "[", "x", "]"}], ",", 
                    RowBox[{"Abs", "[", "y", "]"}]}], "]"}], ",", 
                    RowBox[{"-", "s"}]}], "]"}]}], "]"}], ",", 
                "\[IndentingNewLine]", "\t\t\t\t", 
                RowBox[{"AR", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"x", ">", "0"}], ",", 
                    RowBox[{"Min", "[", 
                    RowBox[{"x", ",", 
                    RowBox[{
                    RowBox[{"-", "x"}], "/", "s"}]}], "]"}], ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{"x", ",", 
                    RowBox[{
                    RowBox[{"-", "x"}], "/", "s"}]}], "]"}]}], "]"}], ",", 
                  "y", ",", 
                  RowBox[{"-", "1"}], ",", 
                  RowBox[{"\"\<RootOrder\>\"", "->", "ord"}]}], "]"}]}], 
               "]"}], "\[IndentingNewLine]", "\t\t\t\t\t", "//", "Flatten"}], 
             ",", "N"}], "]"}], ",", "\[IndentingNewLine]", "\t\t\t\t\t", 
           RowBox[{
            RowBox[{"y", "<=", "#", "<=", "x"}], "&"}]}], "]"}], "//", 
         RowBox[{"DeleteDuplicatesBy", "[", "N", "]"}]}], ",", 
        "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{
         RowBox[{"x", "<=", "y"}], "&&", 
         RowBox[{"s", "<", "0"}]}], ",", "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{
         RowBox[{"x", ">=", "y"}], "&&", 
         RowBox[{"s", ">", "0"}]}], ",", "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t\t\t", "True", ",",
         "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{"{", "x", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\t\t", 
     RowBox[{"test", "=", 
      RowBox[{"VerificationTest", "[", "\[IndentingNewLine]", "\t\t\t\t", 
       RowBox[{
       "input", ",", "expected", ",", "\[IndentingNewLine]", "\t\t\t\t", 
        RowBox[{"TestID", "->", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", "\t\t\t\t\t\t", 
           RowBox[{
            RowBox[{"ToString", "[", "gr", "]"}], ",", "\[IndentingNewLine]", 
            "\t\t\t\t\t\t", 
            RowBox[{"FromLetterNumber", "[", 
             RowBox[{"PreIncrement", "@", "id"}], "]"}], ",", 
            "\[IndentingNewLine]", "\t\t\t\t\t\t", "ID"}], "}"}], "~", 
          "StringRiffle", "~", "\"\<-\>\""}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"Echo", "[", 
      RowBox[{"input", ",", "\"\<input\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"diff", "=", 
      RowBox[{"Differences", "[", "input", "]"}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{"Echo", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"N", "[", "#", "]"}], ",", 
           RowBox[{"#", "<=", 
            RowBox[{"Abs", "[", "s", "]"}]}]}], "}"}], "&"}], "@", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "/@", "diff"}], "]"}]}], ",", "\"\<steps u.b.\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", "\t\t", "test"}]}], "]"}]}]], "Input",\

