Cell[TextData[{
 "Let us plot the resulting ",
 ButtonBox["RepeatedTiming",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/RepeatedTiming"],
 " against the output ",
 ButtonBox["Length",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Length"],
 ", together with their quadratic and linear fits:"
}], "Text",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
     "ServiceDefaultModel" -> <|
      "LLMKit" -> Automatic, "OpenAI" -> "claude-opus-4-6", "Anthropic" -> 
       "claude-opus-4-6"|>, 
     "Model" -> <|"Service" -> "Anthropic", "Name" -> "claude-opus-4-6"|>, 
     "PersonaFavorites" -> {"CodeAssistant", "CodeWriter", "PlainChat"}, 
     "CurrentPreferencesTab" -> "Services", 
     "VisiblePersonas" -> {
      "CodeAssistant", "CodeWriter", "PlainChat", "RawModel"}, 
     "ToolSelections" -> <|
      "DocumentationLookup" -> <|
        "CodeAssistant" -> True, "CodeWriter" -> True|>, 
       "DocumentationSearcher" -> <|
        "CodeAssistant" -> True, "CodeWriter" -> True|>|>|>|>,
 CellChangeTimes->{{3.984120640626317*^9, 3.984120775263402*^9}, {
  3.984242405916059*^9, 3.984242611757391*^9}, {3.984243861786878*^9, 
  3.984243868393201*^9}, {3.984386169677894*^9, 
  3.9843861716724157`*^9}},ExpressionUUID->"142d5152-2074-4781-b21d-\
e702127b10f9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"AC", "=", 
      RowBox[{"ResourceFunction", "[", "\"\<AssociateColumns\>\"", "]"}]}], 
     "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"lsLenTO", "=", 
       RowBox[{"List", "@@@", 
        RowBox[{"Normal", "@", 
         RowBox[{"AC", "[", 
          RowBox[{"tabResults", ",", 
           RowBox[{"\"\<Length\>\"", "->", "\"\<Time Outer\>\""}]}], 
          "]"}]}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"lsLenTA", "=", 
       RowBox[{"List", "@@@", 
        RowBox[{"Normal", "@", 
         RowBox[{"AC", "[", 
          RowBox[{"tabResults", ",", 
           RowBox[{"\"\<Length\>\"", "->", "\"\<Time Actual\>\""}]}], 
          "]"}]}]}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"quadfit", "=", 
       RowBox[{
        RowBox[{"NonlinearModelFit", "[", 
         RowBox[{"lsLenTO", ",", 
          RowBox[{
           RowBox[{"a", " ", 
            RowBox[{"x", "^", "2"}]}], "+", 
           RowBox[{"b", " ", "x"}], " ", "+", " ", "c"}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", "x"}], "]"}], "//", 
        "Normal"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"linfit", "=", 
       RowBox[{
        RowBox[{"LinearModelFit", "[", 
         RowBox[{"lsLenTA", ",", "x", ",", "x"}], "]"}], "//", "Normal"}]}], ",",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"colors", "=", 
       RowBox[{"{", 
        RowBox[{"StandardBlue", ",", "StandardRed"}], "}"}]}], ",", 
      RowBox[{"pt", "=", "15"}], ",", 
      RowBox[{"lsMax", "=", 
       RowBox[{"Max", "[", 
        RowBox[{
         RowBox[{"tabResults", "[", 
          RowBox[{"All", ",", "\"\<Length\>\""}], "]"}], "//", "Normal"}], 
        "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"Show", "[", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"lsLenTO", ",", "lsLenTA"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"Evaluate", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Directive", "[", 
             RowBox[{"#", ",", 
              RowBox[{"PointSize", "[", "Large", "]"}]}], "]"}], "&"}], "/@", 
           "colors"}], "]"}]}], ",", 
        RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"quadfit", ",", "linfit"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", 
          RowBox[{"10", "^", 
           RowBox[{"Ceiling", "[", 
            RowBox[{"Log10", "[", "lsMax", "]"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Outer\\nalgorithm\>\"", ",", "pt"}], "]"}], ",", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Actual\\nalgorithm\>\"", ",", "pt"}], "]"}]}], 
          "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", "colors"}]}], "]"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<Length\>\"", ",", "pt"}], "]"}], ",", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<Timing\>\"", ",", "pt"}], "]"}]}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "InheritanceTest" -> True, 
     "ServiceDefaultModel" -> <|
      "LLMKit" -> Automatic, "OpenAI" -> "claude-opus-4-6", "Anthropic" -> 
       "claude-opus-4-6"|>, 
     "Model" -> <|"Service" -> "Anthropic", "Name" -> "claude-opus-4-6"|>, 
     "PersonaFavorites" -> {"CodeAssistant", "CodeWriter", "PlainChat"}, 
     "CurrentPreferencesTab" -> "Services", 
